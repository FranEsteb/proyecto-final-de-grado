<!-- Ventana de login con diseño moderno y sin bordes
     He diseñado esta ventana con las siguientes características:
     - WindowStyle="None" y AllowsTransparency="True" para un look moderno
     - Tamaño fijo 800x600 y centrada en pantalla
     - Layout de dos paneles: izquierdo decorativo y derecho funcional -->
<Window x:Class="proyectoFinal_Escritorio.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Iniciar Sesión - Sistema de Gestión" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True">
    
    <Window.Resources>
        <!-- Recursos de estilos para el login
             He creado estilos personalizados que siguen el lenguaje de diseño Fluent
             para mantener consistencia visual con el resto de la aplicación -->
        <!-- Estilo personalizado para campos de texto
             He diseñado estos campos con:
             - Bordes redondeados y efecto focus en azul Microsoft (#0078D4)
             - Padding generoso para comodidad de escritura
             - Transiciones suaves entre estados (normal, hover, focus) -->
        <Style x:Key="FluentTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        VerticalAlignment="Center"
                                        Padding="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#C7C7C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para el campo de contraseña
             He replicado el estilo del TextBox para mantener coherencia visual
             entre ambos campos de entrada -->
        <Style x:Key="FluentPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        VerticalAlignment="Center"
                                        Padding="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#C7C7C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para el botón principal de login
             He creado un botón prominente con:
             - Color azul Microsoft (#0078D4) para llamar la atención
             - Estados hover y pressed con tonos más oscuros
             - Estado disabled con colores grises para feedback visual -->
        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F3F3F3"/>
                                <Setter Property="Foreground" Value="#A6A6A6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para el botón de cerrar ventana
             He diseñado este botón minimalista que:
             - Permanece discreto hasta que el usuario lo hoverea
             - Cambia a rojo al hacer hover para indicar acción destructiva
             - Se posiciona en la esquina superior derecha -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Contenedor principal con bordes redondeados y sombra
         He envuelto toda la ventana en este Border para:
         - Añadir esquinas redondeadas (CornerRadius="8") que suavizan el diseño
         - Crear una sombra realista que hace "flotar" la ventana sobre el escritorio
         - Usar un fondo gris muy claro (#F5F5F5) para delimitar la ventana -->
    <Border Background="#F5F5F5" CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="10" BlurRadius="20" Opacity="0.3"/>
        </Border.Effect>
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- Panel izquierdo decorativo
                 He diseñado este panel como elemento visual atractivo:
                 - Gradiente diagonal azul para crear profundidad
                 - Logo círculo blanco con sombra para dar sensación de marca
                 - Textos en blanco sobre fondo azul para contraste óptimo -->
            <!-- Left Panel -->
            <!-- Border con gradiente diagonal para el panel decorativo
                 He usado un gradiente que va desde la esquina superior izquierda
                 hasta la inferior derecha (StartPoint="0,0" EndPoint="1,1")
                 creando un efecto visual dinámico con los colores azules corporativos -->
            <Border Grid.Column="0" CornerRadius="8,0,0,8">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0078D4" Offset="0"/>
                        <GradientStop Color="#005A9E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Sección central del panel izquierdo con logo y textos
                         He centrado todo el contenido verticalmente para equilibrio visual -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Logo circular con sombra
                             He creado un círculo blanco grande que actúa como placeholder del logo
                             con sombra sutil para darle profundidad y separarlo del fondo -->
                        <Ellipse Width="120" Height="120" Fill="White" Opacity="0.9" Margin="0,0,0,30">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="5" BlurRadius="10" Opacity="0.3"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        
                        <TextBlock Text="Sistema de Gestión" 
                                 Foreground="White" 
                                 FontSize="28" 
                                 FontWeight="Light" 
                                 FontFamily="Segoe UI Light"
                                 HorizontalAlignment="Center"
                                 Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Administración y Control" 
                                 Foreground="#E6FFFFFF" 
                                 FontSize="16" 
                                 FontWeight="Light" 
                                 FontFamily="Segoe UI"
                                 HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Panel derecho funcional
                 He diseñado este panel como el área de trabajo donde el usuario interactúa:
                 - Fondo blanco limpio para claridad
                 - Formulario centrado verticalmente
                 - Botón de cerrar en la esquina superior derecha -->
            <!-- Right Panel -->
            <Border Grid.Column="1" Background="White" CornerRadius="0,8,8,0">
                <!-- Grid principal del panel derecho -->
                <Grid>
                    <!-- Botón de cerrar ventana
                         He posicionado este botón en la esquina superior derecha
                         usando el símbolo × para universalidad -->
                    <Button x:Name="CloseButton" 
                            Content="×" 
                            Style="{StaticResource CloseButtonStyle}"
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Top" 
                            Margin="15,15,15,0"
                            Click="CloseButton_Click"/>

                    <!-- Formulario de login centrado verticalmente
                         He usado margins generosos (40px) para evitar que el formulario
                         quede pegado a los bordes y crear espacio respirable -->
                    <StackPanel VerticalAlignment="Center" Margin="40,40,40,60">
                        <TextBlock Text="Iniciar Sesión" 
                                 FontSize="24" 
                                 FontWeight="SemiBold" 
                                 FontFamily="Segoe UI" 
                                 Foreground="#323130"
                                 Margin="0,0,0,30"
                                 HorizontalAlignment="Center"/>

                        <TextBlock Text="Correo electrónico" 
                                 FontSize="14" 
                                 FontFamily="Segoe UI" 
                                 Foreground="#323130"
                                 Margin="0,0,0,8"/>
                        
                        <TextBox x:Name="EmailTextBox" 
                               Style="{StaticResource FluentTextBoxStyle}"
                               Margin="0,0,0,20"
                               Text="admin@test.com"/>

                        <TextBlock Text="Contraseña" 
                                 FontSize="14" 
                                 FontFamily="Segoe UI" 
                                 Foreground="#323130"
                                 Margin="0,0,0,8"/>
                        
                        <PasswordBox x:Name="PasswordBox" 
                                   Style="{StaticResource FluentPasswordBoxStyle}"
                                   Margin="0,0,0,30"/>

                        <Button x:Name="LoginButton"
                              Content="Iniciar sesión" 
                              Style="{StaticResource FluentButtonStyle}"
                              Margin="0,0,0,15"
                              Click="LoginButton_Click"/>

                        <TextBlock x:Name="StatusTextBlock" 
                                 FontSize="12" 
                                 FontFamily="Segoe UI" 
                                 HorizontalAlignment="Center"
                                 Margin="0,15,0,0"
                                 TextWrapping="Wrap"
                                 Visibility="Collapsed"/>
                        
                        <!-- Indicador de carga durante el proceso de login
                             He diseñado este elemento que se muestra mientras se validan las credenciales:
                             - Inicialmente oculto (Visibility="Collapsed")
                             - Fondo gris claro con bordes redondeados para suavidad
                             - Texto centrado que informa al usuario del proceso en curso -->
                        <Grid x:Name="LoadingGrid" Visibility="Collapsed" Margin="0,20,0,0">
                            <Border Background="#F5F5F5" CornerRadius="4" Padding="15">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="Verificando credenciales..." FontSize="12" VerticalAlignment="Center" Foreground="#666666"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
