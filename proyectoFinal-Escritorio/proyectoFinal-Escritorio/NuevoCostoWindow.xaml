<Window x:Class="proyectoFinal_Escritorio.NuevoCostoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registrar Nuevo Costo" Height="600" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FormTextAreaStyle" TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
            <Setter Property="Height" Value="80"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>

        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="35"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="20" BorderBrush="#E1E1E1" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Registrar Nuevo Costo"
                         FontSize="18" FontWeight="SemiBold"
                         Foreground="#323130" Margin="0,0,0,5"/>
                <TextBlock Text="Completa la información del costo de reparación o mantenimiento"
                         FontSize="12" Foreground="#605E5C"/>
            </StackPanel>
        </Border>

        <!-- Formulario -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>

                <!-- Tipo de costo -->
                <TextBlock Text="Tipo de Costo *" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="TipoCostoComboBox" Style="{StaticResource FormComboBoxStyle}"
                        Margin="0,0,0,15">
                    <ComboBoxItem Content="Reparación" Tag="Reparacion" IsSelected="True"/>
                    <ComboBoxItem Content="Mantenimiento" Tag="Mantenimiento"/>
                    <ComboBoxItem Content="Repuesto" Tag="Repuesto"/>
                    <ComboBoxItem Content="Mano de Obra" Tag="ManoDeObra"/>
                    <ComboBoxItem Content="Otro" Tag="Otro"/>
                </ComboBox>

                <!-- Monto -->
                <TextBlock Text="Monto *" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#E1E1E1" Padding="10,8" Height="35" VerticalAlignment="Center">
                        <TextBlock Text="€" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>
                    <TextBox x:Name="MontoTextBox" Grid.Column="1" Style="{StaticResource FormTextBoxStyle}"
                           Margin="0" BorderThickness="1,1,1,1"/>
                </Grid>

                <!-- Fecha -->
                <TextBlock Text="Fecha del Costo *" Style="{StaticResource LabelStyle}"/>
                <DatePicker x:Name="FechaDatePicker" Height="35" Margin="0,0,0,15"
                           BorderBrush="#E1E1E1" BorderThickness="1" Padding="10,8"
                           FontSize="12" FontFamily="Segoe UI"/>

                <!-- Descripción -->
                <TextBlock Text="Descripción *" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="DescripcionTextBox" Style="{StaticResource FormTextAreaStyle}"
                       Margin="0,0,0,15"/>

                <!-- Proveedor -->
                <TextBlock Text="Proveedor" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="ProveedorComboBox" Style="{StaticResource FormComboBoxStyle}"
                        Margin="0,0,0,5"/>

                <!-- Descripción del Proveedor -->
                <TextBlock x:Name="ProveedorDescripcionTextBlock" Text=""
                         FontSize="11" Foreground="#605E5C" TextWrapping="Wrap"
                         Margin="0,0,0,15"/>

                <!-- Técnico -->
                <TextBlock Text="Técnico Asignado" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="TecnicoComboBox" Style="{StaticResource FormComboBoxStyle}"
                        Margin="0,0,0,15">
                    <ComboBoxItem Content="(Sin asignar)"/>
                    <ComboBoxItem Content="Juan Pérez" Tag="Juan Pérez"/>
                    <ComboBoxItem Content="María González" Tag="María González"/>
                    <ComboBoxItem Content="Carlos Ruiz" Tag="Carlos Ruiz"/>
                    <ComboBoxItem Content="Ana Martínez" Tag="Ana Martínez"/>
                </ComboBox>

                <!-- Número de Factura -->
                <TextBlock Text="Número de Factura" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="NumeroFacturaTextBox" Style="{StaticResource FormTextBoxStyle}"
                       Margin="0,0,0,15"/>

                <!-- Observaciones -->
                <TextBlock Text="Observaciones" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="ObservacionesTextBox" Style="{StaticResource FormTextAreaStyle}"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer con botones -->
        <Border Grid.Row="2" Background="White" Padding="20" BorderBrush="#E1E1E1" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                         Text="Los campos marcados con * son obligatorios"
                         VerticalAlignment="Center" FontSize="11" Foreground="#605E5C"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="CancelButton" Content="Cancelar"
                          Style="{StaticResource SecondaryButtonStyle}"
                          Margin="0,0,10,0" Click="CancelButton_Click"/>
                    <Button x:Name="SaveButton" Content="Guardar Costo"
                          Style="{StaticResource FluentButtonStyle}"
                          Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
