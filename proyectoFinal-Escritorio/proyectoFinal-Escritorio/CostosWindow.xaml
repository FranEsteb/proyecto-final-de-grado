<Window x:Class="proyectoFinal_Escritorio.CostosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Control de Costos - Reparación y Mantenimiento"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- Estilos -->
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="SubHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.1" ShadowDepth="2" BlurRadius="8"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#6C757D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5A6268"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#28A745"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#218838"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E4E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E1E4E8"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Control de Costos" Style="{StaticResource HeaderTextStyle}"/>
            <TextBlock Text="Seguimiento y control de gastos de reparación y mantenimiento de máquinas"
                      Style="{StaticResource SubHeaderTextStyle}"/>
        </StackPanel>

        <!-- Estadísticas -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" ShadowDepth="2" BlurRadius="8"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Resumen de Costos" FontSize="16" FontWeight="SemiBold"
                          Foreground="#2C3E50" Margin="0,0,0,15"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total General -->
                    <Border Grid.Column="0" Style="{StaticResource StatCardStyle}" Background="#E8F4F8">
                        <StackPanel>
                            <TextBlock Text="💰 Total General" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TotalGeneralText" Text="0,00 €" FontSize="20" FontWeight="Bold"
                                      Foreground="#0078D4"/>
                        </StackPanel>
                    </Border>

                    <!-- Reparaciones -->
                    <Border Grid.Column="1" Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="🔧 Reparaciones" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TotalReparacionesText" Text="0,00 €" FontSize="18" FontWeight="SemiBold"
                                      Foreground="#E74C3C"/>
                            <TextBlock x:Name="CantidadReparacionesText" Text="0 registros" FontSize="10" Foreground="#999"/>
                        </StackPanel>
                    </Border>

                    <!-- Mantenimiento -->
                    <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="⚙️ Mantenimiento" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TotalMantenimientoText" Text="0,00 €" FontSize="18" FontWeight="SemiBold"
                                      Foreground="#F39C12"/>
                            <TextBlock x:Name="CantidadMantenimientoText" Text="0 registros" FontSize="10" Foreground="#999"/>
                        </StackPanel>
                    </Border>

                    <!-- Repuestos -->
                    <Border Grid.Column="3" Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="🔩 Repuestos" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TotalRepuestosText" Text="0,00 €" FontSize="18" FontWeight="SemiBold"
                                      Foreground="#9B59B6"/>
                        </StackPanel>
                    </Border>

                    <!-- Mano de Obra -->
                    <Border Grid.Column="4" Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="👷 Mano de Obra" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TotalManoDeObraText" Text="0,00 €" FontSize="18" FontWeight="SemiBold"
                                      Foreground="#3498DB"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Filtros y acciones -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" ShadowDepth="2" BlurRadius="8"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Filtro de fecha -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,15,0">
                    <TextBlock Text="Desde:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="12"/>
                    <DatePicker x:Name="FechaDesdeFilter" Width="120" Height="32"
                               SelectedDateChanged="FiltroFecha_Changed"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,15,0">
                    <TextBlock Text="Hasta:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="12"/>
                    <DatePicker x:Name="FechaHastaFilter" Width="120" Height="32"
                               SelectedDateChanged="FiltroFecha_Changed"/>
                </StackPanel>

                <!-- Filtro de tipo -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,15,0">
                    <TextBlock Text="Tipo:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="12"/>
                    <ComboBox x:Name="TipoFilter" Width="130" Height="32"
                             SelectionChanged="TipoFilter_Changed">
                        <ComboBoxItem Content="Todos" IsSelected="True"/>
                        <ComboBoxItem Content="Reparación" Tag="Reparacion"/>
                        <ComboBoxItem Content="Mantenimiento" Tag="Mantenimiento"/>
                        <ComboBoxItem Content="Repuesto" Tag="Repuesto"/>
                        <ComboBoxItem Content="Mano de Obra" Tag="ManoDeObra"/>
                        <ComboBoxItem Content="Otro" Tag="Otro"/>
                    </ComboBox>
                </StackPanel>

                <!-- Spacer -->
                <StackPanel Grid.Column="3"/>

                <!-- Botones de acción -->
                <Button Grid.Column="4" Content="➕ Nuevo Costo" Style="{StaticResource SuccessButtonStyle}"
                       Margin="5,0" Click="NuevoCostoButton_Click"/>
                <Button Grid.Column="5" Content="🔄 Actualizar" Style="{StaticResource SecondaryButtonStyle}"
                       Margin="5,0" Click="RefreshButton_Click"/>
            </Grid>
        </Border>

        <!-- Lista de gastos -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="0">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" ShadowDepth="2" BlurRadius="8"/>
            </Border.Effect>

            <Grid>
                <DataGrid x:Name="CostosDataGrid" Style="{StaticResource DataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fecha" Binding="{Binding FechaFormateada}" Width="100"/>
                        <DataGridTextColumn Header="Tipo" Binding="{Binding TipoCostoCapitalizado}" Width="120"/>
                        <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                        <DataGridTextColumn Header="Monto" Binding="{Binding MontoFormateado}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#E74C3C"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Proveedor" Binding="{Binding Proveedor}" Width="130"/>
                        <DataGridTextColumn Header="Técnico" Binding="{Binding Tecnico}" Width="120"/>
                        <DataGridTextColumn Header="N° Factura" Binding="{Binding NumeroFactura}" Width="100"/>
                        <DataGridTemplateColumn Header="Acciones" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="👁️" ToolTip="Ver detalles"
                                               Background="Transparent" BorderThickness="0"
                                               FontSize="16" Cursor="Hand" Padding="5"
                                               Click="VerDetalleCosto_Click" Tag="{Binding}"/>
                                        <Button Content="🗑️" ToolTip="Eliminar"
                                               Background="Transparent" BorderThickness="0"
                                               FontSize="16" Cursor="Hand" Padding="5"
                                               Click="EliminarCosto_Click" Tag="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Panel de carga -->
                <Border x:Name="LoadingPanel" Background="#F0FFFFFF" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Cargando gastos..." FontSize="16" Foreground="#666"/>
                    </StackPanel>
                </Border>

                <!-- Panel vacío -->
                <Border x:Name="EmptyPanel" Background="White" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📊" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="No hay registros de gastos" FontSize="18" FontWeight="SemiBold"
                                  Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="Comienza agregando un nuevo costo de reparación o mantenimiento"
                                  FontSize="13" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Footer con barra de estado -->
        <Border Grid.Row="4" Background="White" CornerRadius="8" Padding="15" Margin="0,15,0,0">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" ShadowDepth="2" BlurRadius="8"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText" Grid.Column="0" Text="Listo"
                          FontSize="12" Foreground="#666" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Cerrar" Style="{StaticResource SecondaryButtonStyle}"
                       Width="100" Click="CloseButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
