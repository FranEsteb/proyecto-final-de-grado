<Window x:Class="proyectoFinal_Escritorio.MachineFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestión de Máquina" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Reutilizar estilos del MainWindow -->
        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F3F3F3"/>
                                <Setter Property="Foreground" Value="#A6A6A6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F9FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#DEECF9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FluentTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FluentComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FluentDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="Padding" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="4" BlurRadius="8" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Height="70">
            <Border.Effect>
                <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
            </Border.Effect>
            <Grid Margin="30,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText"
                             Text="Nueva Máquina" 
                             FontSize="20" 
                             FontWeight="SemiBold" 
                             FontFamily="Segoe UI" 
                             Foreground="#323130"/>
                    <TextBlock x:Name="SubtitleText"
                             Text="Registrar una nueva máquina en el sistema" 
                             FontSize="12" 
                             FontFamily="Segoe UI" 
                             Foreground="#605E5C"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Form Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20">
                <!-- Información Básica -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Información Básica" 
                                 FontSize="16" FontWeight="SemiBold" 
                                 Margin="0,0,0,15" Foreground="#323130"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 1 -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <Label Content="* Número de Serie:" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="NumeroSerieTextBox" Style="{StaticResource FluentTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <Label Content="* Tipo de Máquina:" Style="{StaticResource LabelStyle}"/>
                                <ComboBox x:Name="TipoComboBox" Style="{StaticResource FluentComboBoxStyle}"/>
                            </StackPanel>

                            <!-- Row 2 -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,15,0,0">
                                <Label Content="Marca:" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="MarcaTextBox" Style="{StaticResource FluentTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,15,0,0">
                                <Label Content="Modelo:" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="ModeloTextBox" Style="{StaticResource FluentTextBoxStyle}"/>
                            </StackPanel>

                            <!-- Row 3 -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,15,0,0">
                                <Label Content="Estado:" Style="{StaticResource LabelStyle}"/>
                                <ComboBox x:Name="EstadoComboBox" Style="{StaticResource FluentComboBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,15,0,0">
                                <Label Content="Ubicación:" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="UbicacionTextBox" Style="{StaticResource FluentTextBoxStyle}"/>
                            </StackPanel>

                            <!-- Row 4 -->
                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,15,0,0">
                                <Label Content="Fecha de Compra:" Style="{StaticResource LabelStyle}"/>
                                <DatePicker x:Name="FechaCompraDatePicker" Style="{StaticResource FluentDatePickerStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,15,0,0">
                                <Label Content="Costo de Compra (€):" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="CostoCompraTextBox" Style="{StaticResource FluentTextBoxStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Especificaciones Técnicas -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Especificaciones Técnicas" 
                                 FontSize="16" FontWeight="SemiBold" 
                                 Margin="0,0,0,15" Foreground="#323130"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 1 -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <Label Content="Peso (kg):" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="PesoTextBox" Style="{StaticResource FluentTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <Label Content="Dimensiones (LxAxH):" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="DimensionesTextBox" Style="{StaticResource FluentTextBoxStyle}" 
                                       Tag="Ej: 120x60x100 cm"/>
                            </StackPanel>

                            <!-- Row 2 -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,15,0,0">
                                <Label Content="Consumo Energía (W):" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="ConsumoEnergiaTextBox" Style="{StaticResource FluentTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,15,0,0">
                                <Label Content="Capacidad Máxima (kg):" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="CapacidadMaximaTextBox" Style="{StaticResource FluentTextBoxStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Mantenimiento y Uso -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Mantenimiento y Uso" 
                                 FontSize="16" FontWeight="SemiBold" 
                                 Margin="0,0,0,15" Foreground="#323130"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 1 -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <Label Content="Horas de Uso:" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="HorasUsoTextBox" Style="{StaticResource FluentTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <Label Content="Próximo Mantenimiento:" Style="{StaticResource LabelStyle}"/>
                                <DatePicker x:Name="MantenimientoProgramadoDatePicker" Style="{StaticResource FluentDatePickerStyle}"/>
                            </StackPanel>

                            <!-- Row 2 -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,15,0,0">
                                <Label Content="Último Mantenimiento:" Style="{StaticResource LabelStyle}"/>
                                <DatePicker x:Name="UltimoMantenimientoDatePicker" Style="{StaticResource FluentDatePickerStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Asignación de Proveedor -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Proveedor"
                                 FontSize="16" FontWeight="SemiBold"
                                 Margin="0,0,0,15" Foreground="#323130"/>

                        <StackPanel>
                            <Label Content="Proveedor Asignado:" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="ProveedorComboBox" Style="{StaticResource FluentComboBoxStyle}"/>
                            <TextBlock x:Name="ProveedorDescripcionTextBlock"
                                     FontSize="11"
                                     Foreground="#605E5C"
                                     Margin="0,8,0,0"
                                     TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Garantía -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Información de Garantía" 
                                 FontSize="16" FontWeight="SemiBold" 
                                 Margin="0,0,0,15" Foreground="#323130"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 1 -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <Label Content="Inicio de Garantía:" Style="{StaticResource LabelStyle}"/>
                                <DatePicker x:Name="GarantiaInicioDatePicker" Style="{StaticResource FluentDatePickerStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <Label Content="Fin de Garantía:" Style="{StaticResource LabelStyle}"/>
                                <DatePicker x:Name="GarantiaFinDatePicker" Style="{StaticResource FluentDatePickerStyle}"/>
                            </StackPanel>

                            <!-- Row 2 -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,15,0,0" Grid.ColumnSpan="3">
                                <Label Content="Proveedor de Garantía:" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="GarantiaProveedorTextBox" Style="{StaticResource FluentTextBoxStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Border Grid.Row="2" Background="White" Height="70" BorderBrush="#E1E1E1" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="30,0">
                <Button x:Name="CancelButton" 
                      Content="Cancelar" 
                      Style="{StaticResource SecondaryButtonStyle}" 
                      Width="100" 
                      Margin="0,0,10,0"
                      Click="CancelButton_Click"/>
                <Button x:Name="SaveButton" 
                      Content="Guardar" 
                      Style="{StaticResource FluentButtonStyle}" 
                      Width="100"
                      Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>