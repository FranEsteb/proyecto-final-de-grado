<!-- Ventana principal del sistema de gestión del gimnasio
     He diseñado esta ventana como el hub central de la aplicación, con un layout de dos columnas:
     - Columna izquierda: Sidebar de navegación con gradiente azul que le da un aspecto moderno
     - Columna derecha: Área de contenido principal que cambia según la selección del usuario
     He optado por maximizar la ventana por defecto para aprovechar todo el espacio de pantalla -->
<Window x:Class="proyectoFinal_Escritorio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:proyectoFinal_Escritorio"
        mc:Ignorable="d"
        Title="Sistema de Gestión - Gimnasio" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Estilos inspirados en Fluent Design para crear una interfaz moderna y consistente
             He definido todos los estilos aquí para reutilizarlos a lo largo de la aplicación
             y mantener un diseño coherente siguiendo las pautas de Microsoft -->
        <!-- Fluent Design Styles -->
        
        <!-- Estilo personalizado para botones de la barra lateral
             He creado un estilo que simula los botones de navegación de aplicaciones modernas:
             - Fondo transparente por defecto con efecto hover sutil
             - Esquinas redondeadas (CornerRadius="8") para suavidad visual
             - Efectos de hover con transparencia (#33FFFFFF) para feedback visual -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                Margin="10,2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para el botón activo de la sidebar
             He extendido el estilo base y añadido un fondo azul (#0078D4) y fontweight
             para indicar claramente cuál es la sección actualmente seleccionada -->
        <Style x:Key="ActiveSidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Estilo para las tarjetas de módulos del dashboard
             He diseñado estas tarjetas con:
             - Fondo blanco limpio y esquinas redondeadas para modernidad
             - Sombra suave (DropShadowEffect) que simula Material Design
             - Cursor de mano para indicar interactividad
             - Padding generoso para mejorar la legibilidad del contenido -->
        <Style x:Key="ModuleCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="4" BlurRadius="8" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#323130"/>
        </Style>

        <Style x:Key="SubHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#605E5C"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="IconStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontFamily" Value="Segoe UI Emoji"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="TopBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F2F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Barra de navegación lateral (Sidebar)
             He diseñado esta barra como el elemento de navegación principal:
             - Gradiente azul de arriba abajo para darle profundidad visual
             - Ancho fijo de 280px para mantener proporciones equilibradas
             - Estructura en tres secciones: header, menú de navegación e info del usuario -->
        <!-- Sidebar Navigation -->
        <Border Grid.Column="0">
            <!-- Gradiente de fondo para la sidebar
                 He utilizado un gradiente linear vertical de azul claro a azul oscuro
                 para crear profundidad y modernidad en la barra lateral -->
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0078D4" Offset="0"/>
                    <GradientStop Color="#005A9E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Sección de encabezado de la sidebar
                     He colocado aquí el logo (círculo blanco) y el nombre del sistema
                     con espaciado generoso para crear una jerarquía visual clara -->
                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="20,30,20,40">
                    <Ellipse Width="60" Height="60" Fill="White" Opacity="0.9" Margin="0,0,0,15"/>
                    <TextBlock Text="Sistema de Gestión" 
                             Foreground="White" 
                             FontSize="18" 
                             FontWeight="SemiBold" 
                             FontFamily="Segoe UI"
                             HorizontalAlignment="Center"/>
                    <TextBlock Text="Gimnasio Premium" 
                             Foreground="#E6FFFFFF" 
                             FontSize="12" 
                             FontFamily="Segoe UI"
                             HorizontalAlignment="Center"
                             Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Menú de navegación principal
                     He organizado todos los módulos del sistema en botones verticales
                     cada uno con su emoji distintivo para facilitar la identificación rápida
                     y he usado ScrollViewer para manejar el overflow si hay muchos elementos -->
                <!-- Navigation Menu -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Button x:Name="DashboardButton" Content="📊 Dashboard" Style="{StaticResource ActiveSidebarButtonStyle}" Click="DashboardButton_Click"/>
                        <Button x:Name="UsuariosButton" Content="👥 Gestión de Usuarios" Style="{StaticResource SidebarButtonStyle}" Click="UsuariosButton_Click"/>
                        <Button x:Name="MaquinasButton" Content="⚙️ Gestión de Máquinas" Style="{StaticResource SidebarButtonStyle}" Click="MaquinasButton_Click"/>
                        <Button x:Name="AveriasButton" Content="🔧 Gestión de Averías" Style="{StaticResource SidebarButtonStyle}" Click="AveriasButton_Click"/>
                        <Button x:Name="ReputacionButton" Content="⭐ Sistema de Reputación" Style="{StaticResource SidebarButtonStyle}" Click="ReputacionButton_Click"/>
                        <Button x:Name="ProveedoresButton" Content="🏪 Gestión de Proveedores" Style="{StaticResource SidebarButtonStyle}" Click="ProveedoresButton_Click"/>
                        
                        <Button x:Name="CostosButton" Content="💰 Control de Costos" Style="{StaticResource SidebarButtonStyle}" Click="CostosButton_Click"/>
                        <Button x:Name="ClasesButton" Content="🏃 Reserva de Clases" Style="{StaticResource SidebarButtonStyle}" Click="ClasesButton_Click"/>
                        <Button x:Name="DescuentosButton" Content="🎁 Gestión de Descuentos" Style="{StaticResource SidebarButtonStyle}" Click="DescuentosButton_Click"/>
                        <Button x:Name="MovilButton" Content="📱 App Móvil" Style="{StaticResource SidebarButtonStyle}" Click="MovilButton_Click"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Sección de información del usuario
                     He diseñado este panel inferior para mostrar quién está conectado:
                     - Fondo semi-transparente negro para destacar sobre el gradiente
                     - Esquinas redondeadas y padding para un aspecto pulido
                     - Botón de cerrar sesión integrado de forma discreta -->
                <!-- User Info -->
                <Border Grid.Row="2" Background="#33000000" CornerRadius="8" Margin="15" Padding="15">
                    <StackPanel>
                        <TextBlock x:Name="UserNameText" Text="Administrador" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock x:Name="UserRoleText" Text="Sistema" Foreground="#CCFFFFFF" FontSize="12" Margin="0,2,0,8"/>
                        <Button Content="Cerrar Sesión" Style="{StaticResource TopBarButtonStyle}" 
                              Foreground="White" FontSize="11" Padding="0" 
                              HorizontalAlignment="Left" Click="LogoutButton_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Área principal de contenido
             He estructurado esta sección en dos partes:
             1. Top Bar: Barra superior con título, descripción y botones de acción
             2. Content Area: Área scrolleable donde se muestra el contenido dinámico
             El fondo gris claro (#F8F9FA) crea contraste con las tarjetas blancas -->
        <!-- Main Content Area -->
        <Grid Grid.Column="1" Background="#F8F9FA">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barra superior del contenido principal
                 He creado esta barra para proporcionar contexto sobre la sección actual:
                 - Fondo blanco con sombra sutil para separación visual
                 - Título dinámico que cambia según la sección seleccionada
                 - Botones de configuración y ayuda alineados a la derecha -->
            <!-- Top Bar -->
            <Border Grid.Row="0" Background="White" Height="60">
                <Border.Effect>
                    <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="30,0">
                        <TextBlock x:Name="CurrentModuleText" Text="Dashboard" Style="{StaticResource HeaderTextStyle}"/>
                        <TextBlock x:Name="CurrentModuleDescription" Text="Vista general del sistema" Style="{StaticResource SubHeaderTextStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,30,0">
                        <Button Content="⚙️ Configuración" Style="{StaticResource TopBarButtonStyle}" Margin="5,0"/>
                        <Button Content="❓ Ayuda" Style="{StaticResource TopBarButtonStyle}" Margin="5,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Área de contenido scrolleable
                 He usado ScrollViewer para permitir desplazamiento cuando hay mucho contenido
                 y he aplicado padding uniforme de 30px para respirabilidad visual -->
            <!-- Content Area -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="30">
                <Grid x:Name="ContentGrid">
                    <!-- Contenido del Dashboard principal
                         He diseñado el dashboard como la pantalla de bienvenida con:
                         - Sección de bienvenida con gradiente atractivo
                         - Grid de 3x3 con tarjetas de módulos organizadas lógicamente
                         - Cada tarjeta es clickeable y navega a su módulo correspondiente -->
                    <!-- Dashboard Content -->
                    <Grid x:Name="DashboardContent" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Sección de bienvenida
                             He creado esta tarjeta especial con gradiente horizontal
                             para dar una bienvenida cálida y explicar cómo usar el sistema -->
                        <!-- Welcome Section -->
                        <Border Grid.Row="0" Style="{StaticResource ModuleCardStyle}" Margin="0,0,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#0078D4" Offset="0"/>
                                    <GradientStop Color="#40E0D0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <TextBlock Text="¡Bienvenido al Sistema de Gestión!" 
                                         Foreground="White" 
                                         FontSize="20" 
                                         FontWeight="SemiBold" 
                                         Margin="0,0,0,10"/>
                                <TextBlock Text="Selecciona un módulo del menú lateral para comenzar a gestionar tu gimnasio" 
                                         Foreground="#E6FFFFFF" 
                                         FontSize="14" 
                                         TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Grid de tarjetas de módulos
                             He organizado los módulos en una cuadrícula de 3 columnas
                             cada tarjeta tiene un emoji distintivo, título y descripción
                             para que los usuarios entiendan rápidamente qué hace cada módulo -->
                        <!-- Module Cards Grid -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 1 -->
                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource ModuleCardStyle}" MouseLeftButtonDown="UsuariosCard_Click">
                                <StackPanel>
                                    <TextBlock Text="👥" Style="{StaticResource IconStyle}"/>
                                    <TextBlock Text="Gestión de Usuarios" Style="{StaticResource HeaderTextStyle}" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Crear, editar, eliminar y filtrar usuarios del sistema" Style="{StaticResource SubHeaderTextStyle}" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource ModuleCardStyle}" MouseLeftButtonDown="MaquinasCard_Click">
                                <StackPanel>
                                    <TextBlock Text="⚙️" Style="{StaticResource IconStyle}"/>
                                    <TextBlock Text="Gestión de Máquinas" Style="{StaticResource HeaderTextStyle}" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Registro, seguimiento y actualización del estado de cada equipo" Style="{StaticResource SubHeaderTextStyle}" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource ModuleCardStyle}" MouseLeftButtonDown="AveriasCard_Click">
                                <StackPanel>
                                    <TextBlock Text="🔧" Style="{StaticResource IconStyle}"/>
                                    <TextBlock Text="Gestión de Averías" Style="{StaticResource HeaderTextStyle}" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Reportar, monitorizar y programar reparaciones de equipos" Style="{StaticResource SubHeaderTextStyle}" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Row 2 -->
                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource ModuleCardStyle}" MouseLeftButtonDown="ReputacionCard_Click">
                                <StackPanel>
                                    <TextBlock Text="⭐" Style="{StaticResource IconStyle}"/>
                                    <TextBlock Text="Sistema de Reputación" Style="{StaticResource HeaderTextStyle}" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Gestión de sanciones y recompensas para clientes" Style="{StaticResource SubHeaderTextStyle}" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ModuleCardStyle}" MouseLeftButtonDown="ProveedoresCard_Click">
                                <StackPanel>
                                    <TextBlock Text="🏪" Style="{StaticResource IconStyle}"/>
                                    <TextBlock Text="Gestión de Proveedores" Style="{StaticResource HeaderTextStyle}" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Seguimiento de pedidos y suministros de repuestos" Style="{StaticResource SubHeaderTextStyle}" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource ModuleCardStyle}" MouseLeftButtonDown="CostosCard_Click">
                                <StackPanel>
                                    <TextBlock Text="💰" Style="{StaticResource IconStyle}"/>
                                    <TextBlock Text="Control de Costos" Style="{StaticResource HeaderTextStyle}" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Seguimiento de gastos de reparación y mantenimiento" Style="{StaticResource SubHeaderTextStyle}" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Row 3 -->
                            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource ModuleCardStyle}" MouseLeftButtonDown="ClasesCard_Click">
                                <StackPanel>
                                    <TextBlock Text="🏃" Style="{StaticResource IconStyle}"/>
                                    <TextBlock Text="Reserva de Clases" Style="{StaticResource HeaderTextStyle}" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Inscripción en actividades y visualización de horarios" Style="{StaticResource SubHeaderTextStyle}" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource ModuleCardStyle}" MouseLeftButtonDown="DescuentosCard_Click">
                                <StackPanel>
                                    <TextBlock Text="🎁" Style="{StaticResource IconStyle}"/>
                                    <TextBlock Text="Gestión de Descuentos" Style="{StaticResource HeaderTextStyle}" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Sistema de descuentos por permanencia para clientes" Style="{StaticResource SubHeaderTextStyle}" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource ModuleCardStyle}" MouseLeftButtonDown="MovilCard_Click">
                                <StackPanel>
                                    <TextBlock Text="📱" Style="{StaticResource IconStyle}"/>
                                    <TextBlock Text="App Móvil" Style="{StaticResource HeaderTextStyle}" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Configuración y gestión de la aplicación móvil" Style="{StaticResource SubHeaderTextStyle}" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- Contenido placeholder para módulos en desarrollo
                         He creado este contenido genérico que se muestra cuando se selecciona
                         un módulo que aún no está completamente implementado
                         incluye un botón para volver al dashboard fácilmente -->
                    <!-- Placeholder for other module content -->
                    <Grid x:Name="ModuleContent" Visibility="Collapsed">
                        <!-- Tarjeta de placeholder centrada para módulos en desarrollo
                             He diseñado esta tarjeta para informar al usuario que el módulo
                             está en desarrollo, usando un emoji de construcción y un botón
                             prominente para regresar al dashboard -->
                        <Border Style="{StaticResource ModuleCardStyle}" VerticalAlignment="Center" HorizontalAlignment="Center" MinWidth="400">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="🚧" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                <TextBlock x:Name="ModulePlaceholderTitle" Text="Módulo en Desarrollo" 
                                         Style="{StaticResource HeaderTextStyle}" 
                                         HorizontalAlignment="Center" 
                                         Margin="0,0,0,10"/>
                                <TextBlock x:Name="ModulePlaceholderDescription" Text="Esta funcionalidad estará disponible próximamente." 
                                         Style="{StaticResource SubHeaderTextStyle}" 
                                         HorizontalAlignment="Center"
                                         TextAlignment="Center"/>
                                <Button Content="Volver al Dashboard" 
                                      Style="{StaticResource TopBarButtonStyle}" 
                                      Margin="0,20,0,0" 
                                      Padding="20,10"
                                      Background="#0078D4"
                                      Foreground="White"
                                      Click="BackToDashboard_Click"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
