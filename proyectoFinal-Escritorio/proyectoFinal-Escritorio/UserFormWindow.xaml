<Window x:Class="proyectoFinal_Escritorio.UserFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Formulario de Usuario" Height="700" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F3F3F3"/>
                                <Setter Property="Foreground" Value="#A6A6A6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F9FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FluentTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        VerticalAlignment="Center"
                                        Padding="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FluentPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        VerticalAlignment="Center"
                                        Padding="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FluentComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="35"/>
        </Style>

        <Style x:Key="FluentDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="35"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="30,20">
            <Border.Effect>
                <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="FormTitleText" Text="Nuevo Usuario" FontSize="20" FontWeight="SemiBold" Foreground="#323130" Margin="0,0,0,5"/>
                <TextBlock x:Name="FormDescriptionText" Text="Complete los campos para crear un nuevo usuario" FontSize="12" Foreground="#605E5C"/>
            </StackPanel>
        </Border>

        <!-- Form Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30">
            <Border Background="White" CornerRadius="8" Padding="30">
                <Border.Effect>
                    <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="4" BlurRadius="8" Opacity="0.4"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <!-- Personal Information -->
                        <TextBlock Text="Información Personal" FontSize="14" FontWeight="SemiBold" Foreground="#323130" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="DNI *" FontSize="12" Foreground="#323130" Margin="0,0,0,5"/>
                        <TextBox x:Name="DniTextBox" Style="{StaticResource FluentTextBoxStyle}" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Nombre *" FontSize="12" Foreground="#323130" Margin="0,0,0,5"/>
                        <TextBox x:Name="NombreTextBox" Style="{StaticResource FluentTextBoxStyle}" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Apellidos *" FontSize="12" Foreground="#323130" Margin="0,0,0,15"/>
                        <TextBox x:Name="ApellidosTextBox" Style="{StaticResource FluentTextBoxStyle}" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Fecha de Nacimiento *" FontSize="12" Foreground="#323130" Margin="0,0,0,5"/>
                        <DatePicker x:Name="FechaNacimientoDatePicker" Style="{StaticResource FluentDatePickerStyle}" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Ciudad" FontSize="12" Foreground="#323130" Margin="0,0,0,5"/>
                        <ComboBox x:Name="CiudadComboBox" Style="{StaticResource FluentComboBoxStyle}" Margin="0,0,0,15" IsEditable="True"/>
                        
                        <TextBlock Text="Teléfono" FontSize="12" Foreground="#323130" Margin="0,0,0,5"/>
                        <TextBox x:Name="TelefonoTextBox" Style="{StaticResource FluentTextBoxStyle}" Margin="0,0,0,15"/>

                        <!-- Membership Information -->
                        <Border BorderThickness="0,1,0,0" BorderBrush="#E1E1E1" Padding="0,10,0,10" Margin="0,15,0,5">
                            <TextBlock Text="Información de Membresía" FontSize="14" FontWeight="SemiBold" Foreground="#323130"/>
                        </Border>

                        <TextBlock Text="¿Membresía Activa?" FontSize="12" Foreground="#323130" Margin="0,0,0,5"/>
                        <CheckBox x:Name="MembresiaActivaCheckBox" Content="Activar membresía" FontSize="12" Margin="0,0,0,15" Checked="MembresiaActivaCheckBox_Checked" Unchecked="MembresiaActivaCheckBox_Unchecked"/>

                        <TextBlock Text="Tipo de Membresía" FontSize="12" Foreground="#323130" Margin="0,0,0,5"/>
                        <ComboBox x:Name="TipoMembresiaComboBox" Style="{StaticResource FluentComboBoxStyle}" Margin="0,0,0,15" IsEnabled="False">
                            <ComboBoxItem Content="Premium" Tag="premium"/>
                            <ComboBoxItem Content="Gold" Tag="gold"/>
                            <ComboBoxItem Content="Básica" Tag="basica"/>
                        </ComboBox>

                        <TextBlock Text="Fecha Inicio Membresía" FontSize="12" Foreground="#323130" Margin="0,0,0,5"/>
                        <DatePicker x:Name="FechaInicioMembresiaDatePicker" Style="{StaticResource FluentDatePickerStyle}" Margin="0,0,0,15" IsEnabled="False"/>

                        <TextBlock Text="Fecha Fin Membresía" FontSize="12" Foreground="#323130" Margin="0,0,0,5"/>
                        <DatePicker x:Name="FechaFinMembresiaDatePicker" Style="{StaticResource FluentDatePickerStyle}" Margin="0,0,0,15" IsEnabled="False"/>

                        <!-- Discount Information -->
                        <Border BorderThickness="0,1,0,0" BorderBrush="#E1E1E1" Padding="0,10,0,10" Margin="0,15,0,5">
                            <TextBlock Text="Información de Descuentos" FontSize="14" FontWeight="SemiBold" Foreground="#323130"/>
                        </Border>

                        <TextBlock Text="Descuento Actual (%)" FontSize="12" Foreground="#323130" Margin="0,0,0,5"/>
                        <TextBox x:Name="DescuentoActualTextBox" Style="{StaticResource FluentTextBoxStyle}" Margin="0,0,0,15" Text="0"/>

                        <TextBlock Text="Motivo del Descuento" FontSize="12" Foreground="#323130" Margin="0,0,0,5"/>
                        <TextBox x:Name="MotivoDescuentoTextBox" Style="{StaticResource FluentTextBoxStyle}" Margin="0,0,0,15" Text="" TextWrapping="Wrap" Height="60" AcceptsReturn="True" VerticalAlignment="Top"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <!-- Account Information -->
                        <TextBlock Text="Información de Cuenta" FontSize="14" FontWeight="SemiBold" Foreground="#323130" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Email *" FontSize="12" Foreground="#323130" Margin="0,0,0,5"/>
                        <TextBox x:Name="EmailTextBox" Style="{StaticResource FluentTextBoxStyle}" Margin="0,0,0,15"/>
                        
                        <TextBlock x:Name="PasswordLabel" Text="Contraseña *" FontSize="12" Foreground="#323130" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource FluentPasswordBoxStyle}" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Rol *" FontSize="12" Foreground="#323130" Margin="0,0,0,5"/>
                        <ComboBox x:Name="RolComboBox" Style="{StaticResource FluentComboBoxStyle}" Margin="0,0,0,15">
                            <ComboBoxItem Content="Administrador" Tag="administrador"/>
                            <ComboBoxItem Content="Empleado" Tag="empleado"/>
                            <ComboBoxItem Content="Cliente" Tag="cliente"/>
                        </ComboBox>

                        <!-- Age Display (Read-only) -->
                        <Border Background="#F8F9FA" CornerRadius="4" Padding="15" Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="Información Calculada" FontSize="12" FontWeight="SemiBold" Foreground="#323130" Margin="0,0,0,10"/>
                                <TextBlock x:Name="EdadDisplayText" Text="Edad: No calculada" FontSize="11" Foreground="#605E5C"/>
                                <TextBlock x:Name="EsMayorEdadText" Text="Estado: No calculado" FontSize="11" Foreground="#605E5C"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Border Grid.Row="2" Background="White" Padding="30,20">
            <Border.Effect>
                <DropShadowEffect Color="#E0E0E0" Direction="90" ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
            </Border.Effect>
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="* Campos obligatorios" FontSize="11" Foreground="#605E5C" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}" Click="CancelButton_Click" Margin="0,0,10,0"/>
                    <Button x:Name="SaveButton" Content="Guardar" Style="{StaticResource FluentButtonStyle}" Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>