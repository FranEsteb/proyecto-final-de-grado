<Window x:Class="proyectoFinal_Escritorio.NuevoPedidoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nuevo Pedido" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                               BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F9FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20">
            <TextBlock x:Name="TitleTextBlock" Text="Nuevo Pedido" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
        </Border>

        <!-- Contenido principal -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- Sección izquierda: productos disponibles -->
            <Grid Grid.Column="0" Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Información del proveedor -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15" BorderBrush="#E1E1E1" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Proveedor" FontSize="11" FontWeight="SemiBold" Foreground="#605E5C"/>
                        <TextBlock x:Name="ProveedorNameTextBlock" Text="-" FontSize="16" FontWeight="SemiBold" Foreground="#323130" Margin="0,5,0,0"/>
                        <TextBlock x:Name="ProveedorCifTextBlock" Text="-" FontSize="11" Foreground="#605E5C" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Lista de productos del proveedor -->
                <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#E1E1E1" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Productos disponibles" FontSize="12" FontWeight="SemiBold" Foreground="#323130" Padding="20,15,20,10"/>
                        <ListBox x:Name="ProductosListBox" BorderThickness="0" Background="Transparent" Padding="10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E1E1E1" BorderThickness="0,0,0,1" Padding="10,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding}" FontSize="12" Foreground="#323130"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Sección derecha: carrito y resumen -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Selector de producto y cantidad -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E1E1E1" BorderThickness="1" Margin="0,0,0,15">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Selecciona producto" FontSize="11" FontWeight="SemiBold" Foreground="#605E5C" Margin="0,0,0,5"/>
                            <ComboBox x:Name="ProductoComboBox" Height="28" Padding="8,4"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Cantidad" FontSize="11" FontWeight="SemiBold" Foreground="#605E5C" Margin="0,0,0,5"/>
                            <TextBox x:Name="CantidadTextBox" Height="28" Padding="8,4" Text="1"/>
                        </StackPanel>

                        <Button Content="➕ Agregar a pedido" Style="{StaticResource FluentButtonStyle}" Click="AgregarButton_Click" Width="Auto"/>
                    </StackPanel>
                </Border>

                <!-- Lista de productos en el pedido -->
                <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#E1E1E1" BorderThickness="1" Margin="0,0,0,15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Productos en pedido" FontSize="12" FontWeight="SemiBold" Foreground="#323130" Padding="20,15,20,10"/>

                        <ListBox Grid.Row="1" x:Name="PedidoListBox" BorderThickness="0" Background="Transparent" Padding="10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E1E1E1" BorderThickness="0,0,0,1" Padding="10,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Producto}" FontSize="12" Foreground="#323130" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Cantidad, StringFormat='Cantidad: {0}'}" FontSize="11" Foreground="#605E5C" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <Button Grid.Column="1" Content="🗑️" Background="Transparent" BorderThickness="0"
                                                   Click="EliminarProductoButton_Click" Width="30" Height="25" Padding="0" Foreground="#D13438"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Resumen y totales -->
                <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E1E1E1" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Total de productos:" FontSize="12" Foreground="#605E5C"/>
                            <TextBlock Grid.Column="1" x:Name="TotalProductosTextBlock" Text="0" FontSize="12" FontWeight="SemiBold" Foreground="#323130"/>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Cantidad total:" FontSize="12" Foreground="#605E5C"/>
                            <TextBlock Grid.Column="1" x:Name="CantidadTotalTextBlock" Text="0" FontSize="12" FontWeight="SemiBold" Foreground="#323130"/>
                        </Grid>

                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="Observaciones (opcional)" FontSize="11" FontWeight="SemiBold" Foreground="#605E5C" Margin="0,0,0,5"/>
                            <TextBox x:Name="ObservacionesTextBox" Height="50" Padding="8,6" BorderBrush="#E1E1E1" BorderThickness="1"
                                    AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Barra de acciones -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E1E1E1" BorderThickness="0,1" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="StatusTextBlock" Text="" FontSize="11" Foreground="#605E5C" VerticalAlignment="Center"/>

                <Button Grid.Column="1" x:Name="GuardarButton" Content="✅ Realizar Pedido" Style="{StaticResource FluentButtonStyle}"
                       Click="GuardarButton_Click" Margin="0,0,10,0"/>
                <Button Grid.Column="2" Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}" Click="CancelarButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
