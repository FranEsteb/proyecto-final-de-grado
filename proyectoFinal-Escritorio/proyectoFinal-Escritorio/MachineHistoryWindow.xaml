<Window x:Class="proyectoFinal_Escritorio.MachineHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:proyectoFinal_Escritorio"
        Title="Historial de Estados - Máquina" Height="600" Width="800"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:StringToTitleCaseConverter x:Key="StringToTitleCaseConverter"/>
        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="4" BlurRadius="8" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Height="70">
            <Border.Effect>
                <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
            </Border.Effect>
            <Grid Margin="30,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Historial de Estados" 
                             FontSize="20" 
                             FontWeight="SemiBold" 
                             FontFamily="Segoe UI" 
                             Foreground="#323130"/>
                    <TextBlock x:Name="MachineInfoText"
                             Text="Seguimiento completo de cambios de estado" 
                             FontSize="12" 
                             FontFamily="Segoe UI" 
                             Foreground="#605E5C"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Machine Info -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Información de la Máquina" 
                             FontSize="14" FontWeight="SemiBold" 
                             Margin="0,0,0,10" Foreground="#323130"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Número de Serie:" FontWeight="SemiBold" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" x:Name="NumeroSerieText" Text="" Margin="0,0,20,0"/>
                        
                        <TextBlock Grid.Column="2" Text="Tipo/Modelo:" FontWeight="SemiBold" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="3" x:Name="TipoModeloText" Text=""/>
                    </Grid>
                </StackPanel>

                <!-- History List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="HistoryItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" 
                                      CornerRadius="6" 
                                      Margin="0,0,0,10" 
                                      Padding="15"
                                      BorderBrush="#E1E1E1"
                                      BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Estado Indicator -->
                                        <StackPanel Grid.Column="0" Grid.RowSpan="3" Orientation="Horizontal" 
                                                  VerticalAlignment="Center" Margin="0,0,15,0">
                                            <Ellipse Width="12" Height="12">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Estado}" Value="operativa">
                                                                <Setter Property="Fill" Value="#107C10"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Estado}" Value="en reparación">
                                                                <Setter Property="Fill" Value="#D13438"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Estado}" Value="fuera de servicio">
                                                                <Setter Property="Fill" Value="#8B0000"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Estado}" Value="mantenimiento">
                                                                <Setter Property="Fill" Value="#FF8C00"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </StackPanel>

                                        <!-- Estado y Fecha -->
                                        <StackPanel Grid.Column="1" Grid.Row="0">
                                            <TextBlock FontWeight="SemiBold" FontSize="14">
                                                <Run Text="Estado: "/>
                                                <Run Text="{Binding Estado, Converter={StaticResource StringToTitleCaseConverter}}" 
                                                     Foreground="#0078D4"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" Grid.Row="0" 
                                                 Text="{Binding FechaFormateada}" 
                                                 FontSize="12" 
                                                 Foreground="#605E5C"
                                                 VerticalAlignment="Top"/>

                                        <!-- Motivo -->
                                        <TextBlock Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2"
                                                 Text="{Binding Motivo}" 
                                                 TextWrapping="Wrap"
                                                 Margin="0,5,0,0"
                                                 FontSize="12"/>

                                        <!-- Usuario -->
                                        <TextBlock Grid.Column="1" Grid.Row="2" Grid.ColumnSpan="2"
                                                 Margin="0,5,0,0">
                                            <Run Text="Por: " FontSize="11" Foreground="#605E5C"/>
                                            <Run Text="{Binding Usuario}" FontSize="11" FontWeight="SemiBold"/>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty State -->
                <StackPanel x:Name="EmptyStatePanel" 
                          Grid.Row="1"
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"
                          Visibility="Collapsed">
                    <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Opacity="0.5"/>
                    <TextBlock Text="No hay historial de cambios disponible" 
                             FontSize="14" 
                             Foreground="#605E5C" 
                             HorizontalAlignment="Center"
                             Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Action Buttons -->
        <Border Grid.Row="2" Background="White" Height="60" BorderBrush="#E1E1E1" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="30,0">
                <Button x:Name="RefreshButton" 
                      Content="🔄 Actualizar" 
                      Style="{StaticResource FluentButtonStyle}" 
                      Width="120" 
                      Margin="0,0,10,0"
                      Click="RefreshButton_Click"/>
                <Button x:Name="CloseButton" 
                      Content="Cerrar" 
                      Style="{StaticResource FluentButtonStyle}" 
                      Width="100"
                      Click="CloseButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>