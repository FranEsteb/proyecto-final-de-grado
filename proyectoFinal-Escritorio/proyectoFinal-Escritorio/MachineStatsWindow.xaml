<Window x:Class="proyectoFinal_Escritorio.MachineStatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Estadísticas de Máquinas" Height="500" Width="700"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="4" BlurRadius="8" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Height="60">
            <Border.Effect>
                <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
            </Border.Effect>
            <Grid Margin="30,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Estadísticas de Máquinas" 
                             FontSize="18" 
                             FontWeight="SemiBold" 
                             FontFamily="Segoe UI" 
                             Foreground="#323130"/>
                    <TextBlock Text="Resumen general del parque de equipos" 
                             FontSize="12" 
                             FontFamily="Segoe UI" 
                             Foreground="#605E5C"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
            <StackPanel>
                <!-- Resumen General -->
                <TextBlock Text="Resumen General" FontSize="16" FontWeight="SemiBold" Margin="10,0,0,15"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource StatCardStyle}" Background="#E3F2FD">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="TotalMaquinasText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#0078D4" HorizontalAlignment="Center"/>
                            <TextBlock Text="Total Máquinas" FontSize="12" Foreground="#605E5C" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource StatCardStyle}" Background="#E8F5E8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="OperativasText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#107C10" HorizontalAlignment="Center"/>
                            <TextBlock Text="Operativas" FontSize="12" Foreground="#605E5C" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource StatCardStyle}" Background="#FFEBEE">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="EnReparacionText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#D13438" HorizontalAlignment="Center"/>
                            <TextBlock Text="En Reparación" FontSize="12" Foreground="#605E5C" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource StatCardStyle}" Background="#FFF3E0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="MantenimientoText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#FF8C00" HorizontalAlignment="Center"/>
                            <TextBlock Text="Mantenimiento" FontSize="12" Foreground="#605E5C" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Por Tipo -->
                <TextBlock Text="Distribución por Tipo" FontSize="16" FontWeight="SemiBold" Margin="10,0,0,15"/>
                <Border Style="{StaticResource StatCardStyle}" Margin="5,0,5,20">
                    <ListBox x:Name="TipoStatsListBox" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Tipo}" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Cantidad}" Foreground="#0078D4" FontWeight="Bold"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- Loading indicator -->
                <Border x:Name="LoadingPanel" 
                      Style="{StaticResource StatCardStyle}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📊" FontSize="32" HorizontalAlignment="Center" Opacity="0.5"/>
                        <TextBlock Text="Cargando estadísticas..." 
                                 FontSize="14" 
                                 Foreground="#605E5C" 
                                 HorizontalAlignment="Center"
                                 Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Border Grid.Row="2" Background="White" Height="60" BorderBrush="#E1E1E1" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="30,0">
                <Button x:Name="RefreshButton" 
                      Content="🔄 Actualizar" 
                      Style="{StaticResource FluentButtonStyle}" 
                      Width="120" 
                      Margin="0,0,10,0"
                      Click="RefreshButton_Click"/>
                <Button x:Name="CloseButton" 
                      Content="Cerrar" 
                      Style="{StaticResource FluentButtonStyle}" 
                      Width="100"
                      Click="CloseButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>