<!-- Ventana simple para crear nuevas averías
     He diseñado esta ventana con solo los campos esenciales:
     - Elemento afectado
     - Descripción del problema
     - Prioridad
     - Observaciones opcionales
     
     El formulario es compacto y fácil de usar -->
<Window x:Class="proyectoFinal_Escritorio.NuevaAveriaSimpleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nueva Avería" Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Estilos simples -->
        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FormTextAreaStyle" TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
            <Setter Property="Height" Value="80"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>

        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="35"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <!-- Fondo gris claro -->
    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Formulario -->
            <RowDefinition Height="*"/>
            <!-- Botones -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="20" BorderBrush="#E1E1E1" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Reportar Nueva Avería" 
                         FontSize="18" FontWeight="SemiBold" 
                         Foreground="#323130" Margin="0,0,0,5"/>
                <TextBlock Text="Completa la información básica del problema" 
                         FontSize="12" Foreground="#605E5C"/>
            </StackPanel>
        </Border>

        <!-- Formulario -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>
                
                <!-- Elemento afectado -->
                <TextBlock Text="¿Qué elemento está afectado? *" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="ElementoAfectadoTextBox" Style="{StaticResource FormTextBoxStyle}"
                       Margin="0,0,0,15"
                       Tag="Ej: Cinta de correr #3, Aire acondicionado zona cardio, Ducha vestuario..."/>

                <!-- Descripción del problema -->
                <TextBlock Text="Descripción del problema *" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="DescripcionTextBox" Style="{StaticResource FormTextAreaStyle}"
                       Margin="0,0,0,15"
                       Tag="Describe detalladamente qué está fallando"/>

                <!-- Prioridad -->
                <TextBlock Text="Prioridad *" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="PrioridadComboBox" Style="{StaticResource FormComboBoxStyle}"
                        Margin="0,0,0,15">
                    <ComboBoxItem Content="Baja - No urgente" Tag="baja"/>
                    <ComboBoxItem Content="Media - Moderada" Tag="media" IsSelected="True"/>
                    <ComboBoxItem Content="Alta - Urgente" Tag="alta"/>
                </ComboBox>

                <!-- Costo estimado de reparación -->
                <TextBlock Text="Costo Estimado de Reparación *" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#E1E1E1" Padding="10,8" Height="35" VerticalAlignment="Center">
                        <TextBlock Text="€" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>
                    <TextBox x:Name="CostoReparacionTextBox" Grid.Column="1" Style="{StaticResource FormTextBoxStyle}"
                           Margin="0" BorderThickness="1,1,1,1"/>
                </Grid>

                <!-- Observaciones adicionales -->
                <TextBlock Text="Observaciones adicionales (opcional)" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="ObservacionesTextBox" Style="{StaticResource FormTextAreaStyle}"
                       Tag="Cualquier información adicional que pueda ser útil"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Botones -->
        <Border Grid.Row="2" Background="White" Padding="20" BorderBrush="#E1E1E1" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                         Text="Los campos marcados con * son obligatorios" 
                         VerticalAlignment="Center" FontSize="11" Foreground="#605E5C"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="CancelButton" Content="Cancelar" 
                          Style="{StaticResource SecondaryButtonStyle}" 
                          Margin="0,0,10,0" Click="CancelButton_Click"/>
                    <Button x:Name="SaveButton" Content="Reportar Avería" 
                          Style="{StaticResource FluentButtonStyle}" 
                          Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>