<!-- Ventana de gestión de máquinas del gimnasio
     He diseñado esta ventana como un CRUD completo para máquinas:
     - Layout de 4 filas: Header, Filtros, Lista principal, Status bar
     - Maximizada por defecto para aprovechar el espacio del DataGrid
     - Diseño responsivo que se adapta al redimensionamiento -->
<Window x:Class="proyectoFinal_Escritorio.MaquinasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestión de Máquinas - Sistema de Gestión" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Convertidores para binding de datos
             He incluido este convertidor estándar para convertir valores booleanos
             a Visibility (Visible/Collapsed) en el binding de notificaciones -->
        <!-- Convertidores -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Estilos Fluent Design personalizados
             He creado una paleta de estilos coherente siguiendo el lenguaje visual de Microsoft
             con diferentes variantes de botones según su propósito (primario, secundario, éxito, advertencia, peligro) -->
        <!-- Estilos Fluent Design -->
        <!-- Estilo base para botones primarios
             He definido este como el estilo principal con color azul Microsoft
             y efectos hover/pressed para feedback visual inmediato -->
        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F3F3F3"/>
                                <Setter Property="Foreground" Value="#A6A6A6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para botones secundarios
             He diseñado estos botones con fondo blanco y borde azul
             para acciones menos prominentes pero igual de importantes -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F9FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#DEECF9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botones de éxito/confirmación en verde
             He usado tonos de verde para acciones positivas como confirmar operaciones -->
        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}">
            <Setter Property="Background" Value="#107C10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0E6B0E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Botones de advertencia en naranja
             He elegido naranja para acciones que requieren atención como mantenimiento -->
        <Style x:Key="WarningButtonStyle" TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}">
            <Setter Property="Background" Value="#FF8C00"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E67E00"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Botones de peligro en rojo
             He usado rojo para acciones destructivas como eliminar máquinas
             el color alerta al usuario sobre la naturaleza irreversible de la acción -->
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}">
            <Setter Property="Background" Value="#D13438"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#A4262C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FluentTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#0078D4"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FluentComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="28"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="4" BlurRadius="8" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Template personalizado para visualizar el estado de la máquina
             He diseñado este template para mostrar el estado con un indicador visual:
             - Círculo de color que cambia según el estado (verde=operativa, rojo=reparación, etc.)
             - Texto del estado capitalizado para mejor presentación -->
        <!-- Convertidor para el estado de la máquina -->
        <DataTemplate x:Key="EstadoDataTemplate">
            <!-- Layout horizontal con indicador de color y texto
                 He combinado un círculo pequeño de 8px con el texto del estado
                 para crear una visualización rápida y clara del estado actual -->
            <StackPanel Orientation="Horizontal">
                <!-- Indicador circular de estado con colores semánticos
                     He definido colores intuitivos:
                     - Verde (#107C10): Máquina operativa
                     - Rojo (#D13438): En reparación
                     - Rojo oscuro (#8B0000): Fuera de servicio
                     - Naranja (#FF8C00): En mantenimiento -->
                <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Estado}" Value="operativa">
                                    <Setter Property="Fill" Value="#107C10"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Estado}" Value="en reparación">
                                    <Setter Property="Fill" Value="#D13438"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Estado}" Value="fuera de servicio">
                                    <Setter Property="Fill" Value="#8B0000"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Estado}" Value="mantenimiento">
                                    <Setter Property="Fill" Value="#FF8C00"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding EstadoCapitalizado}" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Encabezado principal de la ventana
             He diseñado este header con:
             - Fondo blanco con sombra para separación visual del contenido
             - Altura fija de 80px para proporciones equilibradas
             - Información del módulo a la izquierda y botones de acción a la derecha -->
        <!-- Header -->
        <Border Grid.Row="0" Background="White" Height="80">
            <Border.Effect>
                <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
            </Border.Effect>
            <Grid Margin="30,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Gestión de Máquinas" 
                             FontSize="24" 
                             FontWeight="SemiBold" 
                             FontFamily="Segoe UI" 
                             Foreground="#323130"/>
                    <TextBlock Text="Registro, seguimiento y actualización del estado de cada equipo" 
                             FontSize="14" 
                             FontFamily="Segoe UI" 
                             Foreground="#605E5C"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BackButton" 
                          Content="⬅️ Volver" 
                          Style="{StaticResource SecondaryButtonStyle}" 
                          Margin="5,0"
                          Click="BackButton_Click"/>
                    <Button x:Name="RefreshButton" 
                          Content="🔄 Actualizar" 
                          Style="{StaticResource SecondaryButtonStyle}" 
                          Margin="5,0"
                          Click="RefreshButton_Click"/>
                    <Button x:Name="StatsButton" 
                          Content="📊 Estadísticas" 
                          Style="{StaticResource SecondaryButtonStyle}" 
                          Margin="5,0"
                          Click="StatsButton_Click"/>
                    <Button x:Name="NewMachineButton" 
                          Content="➕ Nueva Máquina" 
                          Style="{StaticResource FluentButtonStyle}" 
                          Margin="5,0"
                          Click="NewMachineButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Panel de filtros y búsqueda
             He creado esta sección para permitir al usuario filtrar las máquinas:
             - Campo de búsqueda por texto libre (número serie, marca, modelo)
             - ComboBoxes para filtrar por tipo, estado y ubicación
             - Botón para limpiar todos los filtros rápidamente -->
        <!-- Filtros y búsqueda -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="30,20,30,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="Filtros y Búsqueda" 
                         FontSize="16" FontWeight="SemiBold" 
                         Margin="0,0,0,15" Foreground="#323130"/>
                
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox x:Name="SearchTextBox" 
                           Grid.Column="0"
                           Style="{StaticResource FluentTextBoxStyle}"
                           Margin="0,0,10,0"
                           TextChanged="SearchTextBox_TextChanged"
                           Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                           Tag="Buscar por número de serie, marca, modelo..."/>
                    
                    <ComboBox x:Name="TipoFilterComboBox" 
                            Grid.Column="1"
                            Style="{StaticResource FluentComboBoxStyle}"
                            Margin="0,0,10,0"
                            SelectionChanged="FilterChanged"
                            DisplayMemberPath="."
                            SelectedValuePath="."/>
                    
                    <ComboBox x:Name="EstadoFilterComboBox" 
                            Grid.Column="2"
                            Style="{StaticResource FluentComboBoxStyle}"
                            Margin="0,0,10,0"
                            SelectionChanged="FilterChanged"
                            DisplayMemberPath="."
                            SelectedValuePath="."/>
                    
                    <ComboBox x:Name="UbicacionFilterComboBox" 
                            Grid.Column="3"
                            Style="{StaticResource FluentComboBoxStyle}"
                            Margin="0,0,10,0"
                            SelectionChanged="FilterChanged"
                            DisplayMemberPath="."
                            SelectedValuePath="."/>
                    
                    <Button x:Name="ClearFiltersButton" 
                          Grid.Column="4"
                          Content="🗑️ Limpiar"
                          Style="{StaticResource SecondaryButtonStyle}"
                          Click="ClearFiltersButton_Click"/>
                </Grid>
            </Grid>
        </Border>

        <!-- DataGrid principal con la lista de máquinas
             He configurado este DataGrid como el elemento central de la ventana:
             - Columnas organizadas lógicamente de izquierda a derecha
             - Botones de acción en cada fila para operaciones rápidas
             - Colores alternados en filas para mejor legibilidad -->
        <!-- Lista de máquinas -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="30,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock x:Name="MachineCountText"
                             Text="Máquinas registradas"
                             FontSize="16" FontWeight="SemiBold"
                             Foreground="#323130"/>
                </Grid>
                
                <!-- DataGrid configurado para óptima experiencia de usuario
                     He personalizado este DataGrid con las siguientes características:
                     - AutoGenerateColumns="False" para control total sobre las columnas
                     - Altura de fila de 40px para comodidad visual
                     - Líneas de separación horizontales sutiles (#F0F0F0)
                     - Fondo alternado en filas para mejor scaneabilidad
                     - Doble clic para editar y selección simple -->
                <DataGrid Grid.Row="1" 
                        x:Name="MachinesDataGrid"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        CanUserReorderColumns="True"
                        CanUserResizeColumns="True"
                        CanUserResizeRows="False"
                        CanUserSortColumns="True"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        HorizontalGridLinesBrush="#F0F0F0"
                        Background="White"
                        AlternatingRowBackground="#F8F9FA"
                        RowHeight="40"
                        FontSize="12"
                        FontFamily="Segoe UI"
                        SelectionMode="Single"
                        SelectionChanged="MachinesDataGrid_SelectionChanged"
                        MouseDoubleClick="MachinesDataGrid_MouseDoubleClick">
                    
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="N° Serie" 
                                          Binding="{Binding NumeroSerie}" 
                                          Width="120"
                                          IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTextColumn Header="Tipo" 
                                          Binding="{Binding TipoCapitalizado}" 
                                          Width="100"
                                          IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTextColumn Header="Marca/Modelo" 
                                          Binding="{Binding MarcaModelo}" 
                                          Width="150"
                                          IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTemplateColumn Header="Estado" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentPresenter Content="{Binding}" 
                                                    ContentTemplate="{StaticResource EstadoDataTemplate}" 
                                                    VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTextColumn Header="Ubicación" 
                                          Binding="{Binding UbicacionDisplay}" 
                                          Width="120"
                                          IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTextColumn Header="Horas Uso"
                                          Binding="{Binding HorasUsoFormateadas}"
                                          Width="80"
                                          IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Costo Reparación"
                                          Binding="{Binding CostoReparacionFormateado}"
                                          Width="120"
                                          IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#D13438"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Costo Mantenimiento"
                                          Binding="{Binding CostoMantenimientoFormateado}"
                                          Width="140"
                                          IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#FF8C00"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Costo Total"
                                          Binding="{Binding CostoTotalFormateado}"
                                          Width="120"
                                          IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#107C10"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTextColumn Header="Mantenimiento" 
                                          Binding="{Binding MantenimientoFormateado}" 
                                          Width="120"
                                          IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MantenimientoVencido}" Value="True">
                                            <Setter Property="Foreground" Value="#D13438"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTextColumn Header="Proveedor" 
                                          Binding="{Binding ProveedorNombre}" 
                                          Width="120"
                                          IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <!-- Columna de acciones con botones de operación
                             He diseñado esta columna con 6 botones principales:
                             - Ver detalles (👁️): Información completa de la máquina
                             - Editar (✏️): Modificar datos de la máquina
                             - Estado (🔧): Cambiar estado operacional
                             - Costos (💰): Gestionar gastos de reparación y mantenimiento
                             - Historial (🕒): Ver historial de cambios
                             - Eliminar (🗁️): Borrar máquina (acción destructiva) -->
                        <DataGridTemplateColumn Header="Acciones" Width="250">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="👁️" 
                                              Style="{StaticResource SecondaryButtonStyle}"
                                              Width="30" Height="26"
                                              Margin="2" Padding="0"
                                              FontSize="10"
                                              ToolTip="Ver detalles"
                                              Click="ViewMachineButton_Click"
                                              Tag="{Binding}"/>
                                        <Button Content="✏️" 
                                              Style="{StaticResource FluentButtonStyle}"
                                              Width="30" Height="26"
                                              Margin="2" Padding="0"
                                              FontSize="10"
                                              ToolTip="Editar máquina"
                                              Click="EditMachineButton_Click"
                                              Tag="{Binding}"/>
                                        <Button Content="🔧"
                                              Style="{StaticResource WarningButtonStyle}"
                                              Width="30" Height="26"
                                              Margin="2" Padding="0"
                                              FontSize="10"
                                              ToolTip="Actualizar estado"
                                              Click="UpdateStateButton_Click"
                                              Tag="{Binding}"/>
                                        <Button Content="💰"
                                              Style="{StaticResource FluentButtonStyle}"
                                              Width="30" Height="26"
                                              Margin="2" Padding="0"
                                              FontSize="10"
                                              ToolTip="Gestionar gastos"
                                              Click="ManageCostsButton_Click"
                                              Tag="{Binding}"/>
                                        <Button Content="🕒" 
                                              Style="{StaticResource SecondaryButtonStyle}"
                                              Width="30" Height="26"
                                              Margin="2" Padding="0"
                                              FontSize="10"
                                              ToolTip="Ver historial"
                                              Click="ViewHistoryButton_Click"
                                              Tag="{Binding}"/>
                                        <Button Content="🗑️" 
                                              Style="{StaticResource DangerButtonStyle}"
                                              Width="30" Height="26"
                                              Margin="2" Padding="0"
                                              FontSize="10"
                                              ToolTip="Eliminar máquina"
                                              Click="DeleteMachineButton_Click"
                                              Tag="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Barra de estado inferior
             He incluido esta barra para mostrar información contextual:
             - Estado actual de la aplicación a la izquierda
             - Timestamp de la última actualización a la derecha
             - Altura fija de 30px y borde superior sutil para delimitación -->
        <!-- Status Bar -->
        <!-- Barra inferior con información de estado
             He estructurado esta barra en dos columnas para mostrar:
             - Izquierda: Estado actual ("Listo", "Cargando", "Error", etc.)
             - Derecha: Información temporal como última actualización
             Uso colores de texto sutiles (#605E5C) para no distraer del contenido principal -->
        <Border Grid.Row="3" Background="White" Height="30" BorderBrush="#E1E1E1" BorderThickness="0,1,0,0">
            <Grid Margin="30,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                         x:Name="StatusText"
                         Text="Listo" 
                         VerticalAlignment="Center"
                         FontSize="11" 
                         Foreground="#605E5C"/>
                
                <TextBlock Grid.Column="1" 
                         x:Name="LastUpdateText"
                         Text="" 
                         VerticalAlignment="Center"
                         FontSize="11" 
                         Foreground="#605E5C"/>
            </Grid>
        </Border>
    </Grid>
</Window>