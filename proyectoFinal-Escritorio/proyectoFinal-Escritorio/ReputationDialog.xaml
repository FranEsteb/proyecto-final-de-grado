<Window x:Class="proyectoFinal_Escritorio.ReputationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aplicar Reputación" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FluentTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="4" BlurRadius="8" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Height="60">
            <Border.Effect>
                <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
            </Border.Effect>
            <Grid Margin="20,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText"
                             Text="Aplicar Reputación" 
                             FontSize="18" 
                             FontWeight="SemiBold" 
                             FontFamily="Segoe UI" 
                             Foreground="#323130"/>
                    <TextBlock x:Name="SubtitleText"
                             Text="Especifica el motivo para la acción" 
                             FontSize="12" 
                             FontFamily="Segoe UI" 
                             Foreground="#605E5C"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <!-- Información -->
                <Border x:Name="InfoBorder" Background="#E3F2FD" CornerRadius="6" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock x:Name="MessageText" 
                                 Text="¿Por qué motivo deseas aplicar esta acción?" 
                                 FontWeight="SemiBold" 
                                 FontSize="14"
                                 Margin="0,0,0,8" 
                                 Foreground="#323130"/>
                        <TextBlock x:Name="PointsText" 
                                 Text="Puntos: +5" 
                                 FontSize="12"
                                 Foreground="#605E5C"/>
                    </StackPanel>
                </Border>

                <!-- Motivo personalizado -->
                <StackPanel Margin="0,0,0,15">
                    <Label Content="* Motivo detallado:" 
                         FontWeight="SemiBold" 
                         FontSize="12"
                         Padding="0,0,0,5"/>
                    <TextBox x:Name="MotivoTextBox" 
                           Style="{StaticResource FluentTextBoxStyle}"
                           Height="80"
                           TextWrapping="Wrap"
                           AcceptsReturn="True"
                           VerticalContentAlignment="Top"/>
                </StackPanel>

                <!-- Motivos predefinidos -->
                <StackPanel>
                    <Label Content="Motivos comunes:" 
                         FontWeight="SemiBold" 
                         FontSize="12"
                         Padding="0,0,0,5"/>
                    <ItemsControl x:Name="PredefinedReasonsPanel">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" 
                                      Style="{StaticResource SecondaryButtonStyle}"
                                      Margin="0,2"
                                      HorizontalAlignment="Stretch"
                                      Click="PredefinedReasonButton_Click"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Action Buttons -->
        <Border Grid.Row="2" Background="White" Height="60" BorderBrush="#E1E1E1" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20,0">
                <Button x:Name="CancelButton" 
                      Content="Cancelar" 
                      Style="{StaticResource SecondaryButtonStyle}" 
                      Width="100" 
                      Margin="0,0,10,0"
                      Click="CancelButton_Click"/>
                <Button x:Name="ApplyButton" 
                      Content="Aplicar" 
                      Style="{StaticResource FluentButtonStyle}" 
                      Width="100"
                      Click="ApplyButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>