<Window x:Class="proyectoFinal_Escritorio.ReputationHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historial de Reputación" Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        WindowState="Normal">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="4" BlurRadius="8" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Template para tipo de reputación -->
        <DataTemplate x:Key="TipoReputacionTemplate">
            <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Tipo}" Value="recompensa">
                                <Setter Property="Background" Value="#E8F5E8"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Tipo}" Value="sancion">
                                <Setter Property="Background" Value="#FFEBEE"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Tipo}" Value="recompensa">
                                    <Setter Property="Text" Value="✅ Recompensa"/>
                                    <Setter Property="Foreground" Value="#107C10"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Tipo}" Value="sancion">
                                    <Setter Property="Text" Value="❌ Sanción"/>
                                    <Setter Property="Foreground" Value="#D13438"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </DataTemplate>

        <!-- Template para puntos -->
        <DataTemplate x:Key="PuntosDataTemplate">
            <TextBlock Text="{Binding Puntos}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EsPositivo}" Value="True">
                                <Setter Property="Foreground" Value="#107C10"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding EsPositivo}" Value="False">
                                <Setter Property="Foreground" Value="#D13438"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Height="70">
            <Border.Effect>
                <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
            </Border.Effect>
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText"
                             Text="Historial de Reputación" 
                             FontSize="20" 
                             FontWeight="SemiBold" 
                             FontFamily="Segoe UI" 
                             Foreground="#323130"/>
                    <TextBlock x:Name="SubtitleText"
                             Text="Historial completo de cambios de reputación" 
                             FontSize="12" 
                             FontFamily="Segoe UI" 
                             Foreground="#605E5C"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="RefreshButton" 
                          Content="🔄 Actualizar" 
                          Style="{StaticResource SecondaryButtonStyle}" 
                          Margin="5,0"
                          Click="RefreshButton_Click"/>
                    <Button x:Name="CloseButton" 
                          Content="❌ Cerrar" 
                          Style="{StaticResource SecondaryButtonStyle}" 
                          Margin="5,0"
                          Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Información del usuario -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="20,15,20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Cliente" FontSize="11" Foreground="#605E5C" Margin="0,0,0,5"/>
                    <TextBlock x:Name="ClienteText" Text="Cargando..." FontSize="14" FontWeight="SemiBold" Foreground="#323130"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1">
                    <TextBlock Text="DNI" FontSize="11" Foreground="#605E5C" Margin="0,0,0,5"/>
                    <TextBlock x:Name="DniText" Text="Cargando..." FontSize="14" FontWeight="SemiBold" Foreground="#323130"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Reputación Actual" FontSize="11" Foreground="#605E5C" Margin="0,0,0,5"/>
                    <TextBlock x:Name="ReputacionActualText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#0078D4"/>
                </StackPanel>
                
                <StackPanel Grid.Column="3">
                    <TextBlock Text="Total de Registros" FontSize="11" Foreground="#605E5C" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TotalRegistrosText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#323130"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Lista de historial -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="20,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" 
                         Text="Registro de Cambios" 
                         FontSize="16" FontWeight="SemiBold" 
                         Margin="0,0,0,15" Foreground="#323130"/>
                
                <DataGrid Grid.Row="1" 
                        x:Name="HistoryDataGrid"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        CanUserReorderColumns="True"
                        CanUserResizeColumns="True"
                        CanUserResizeRows="False"
                        CanUserSortColumns="True"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        HorizontalGridLinesBrush="#F0F0F0"
                        Background="White"
                        AlternatingRowBackground="#F8F9FA"
                        RowHeight="45"
                        FontSize="12"
                        FontFamily="Segoe UI"
                        SelectionMode="Single">
                    
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fecha" 
                                          Binding="{Binding FechaFormateada}" 
                                          Width="120"
                                          IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="11"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTemplateColumn Header="Tipo" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentPresenter Content="{Binding}" 
                                                    ContentTemplate="{StaticResource TipoReputacionTemplate}" 
                                                    VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTextColumn Header="Motivo" 
                                          Binding="{Binding Motivo}" 
                                          Width="*"
                                          IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="MaxHeight" Value="40"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTemplateColumn Header="Puntos" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentPresenter Content="{Binding}" 
                                                    ContentTemplate="{StaticResource PuntosDataTemplate}" 
                                                    VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="White" Height="30" BorderBrush="#E1E1E1" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                         x:Name="StatusText"
                         Text="Listo" 
                         VerticalAlignment="Center"
                         FontSize="11" 
                         Foreground="#605E5C"/>
                
                <TextBlock Grid.Column="1" 
                         x:Name="LastUpdateText"
                         Text="" 
                         VerticalAlignment="Center"
                         FontSize="11" 
                         Foreground="#605E5C"/>
            </Grid>
        </Border>
    </Grid>
</Window>