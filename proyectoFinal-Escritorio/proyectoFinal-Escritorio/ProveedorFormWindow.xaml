<Window x:Class="proyectoFinal_Escritorio.ProveedorFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Formulario de Proveedor" Height="700" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F3F3F3"/>
                                <Setter Property="Foreground" Value="#A6A6A6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F9FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FluentTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FluentTextAreaStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="ErrorLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D13438"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20">
            <TextBlock x:Name="TitleTextBlock" Text="Nuevo Proveedor" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
        </Border>

        <!-- Formulario -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>
                <!-- Nombre -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Nombre del Proveedor *" FontSize="12" FontWeight="SemiBold" Foreground="#323130"/>
                    <TextBox x:Name="NombreTextBox" Style="{StaticResource FluentTextBoxStyle}" Margin="0,5,0,0"/>
                    <TextBlock x:Name="NombreError" Style="{StaticResource ErrorLabelStyle}"/>
                </StackPanel>

                <!-- CIF -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="CIF" FontSize="12" FontWeight="SemiBold" Foreground="#323130"/>
                    <TextBox x:Name="CifTextBox" Style="{StaticResource FluentTextBoxStyle}" Margin="0,5,0,0"/>
                    <TextBlock x:Name="CifError" Style="{StaticResource ErrorLabelStyle}"/>
                </StackPanel>

                <!-- Dirección -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Dirección" FontSize="12" FontWeight="SemiBold" Foreground="#323130"/>
                    <TextBox x:Name="DireccionTextBox" Style="{StaticResource FluentTextBoxStyle}" Margin="0,5,0,0"/>
                    <TextBlock x:Name="DireccionError" Style="{StaticResource ErrorLabelStyle}"/>
                </StackPanel>

                <!-- Teléfono -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Teléfono" FontSize="12" FontWeight="SemiBold" Foreground="#323130"/>
                    <TextBox x:Name="TelefonoTextBox" Style="{StaticResource FluentTextBoxStyle}" Margin="0,5,0,0"/>
                    <TextBlock x:Name="TelefonoError" Style="{StaticResource ErrorLabelStyle}"/>
                </StackPanel>

                <!-- Email -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Email" FontSize="12" FontWeight="SemiBold" Foreground="#323130"/>
                    <TextBox x:Name="EmailTextBox" Style="{StaticResource FluentTextBoxStyle}" Margin="0,5,0,0"/>
                    <TextBlock x:Name="EmailError" Style="{StaticResource ErrorLabelStyle}"/>
                </StackPanel>

                <!-- Productos -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Productos Suministrados" FontSize="12" FontWeight="SemiBold" Foreground="#323130"/>
                    <TextBox x:Name="ProductosTextBox" Style="{StaticResource FluentTextAreaStyle}" Height="80" Margin="0,5,0,0"
                            ToolTip="Ingresa los productos separados por comas"/>
                    <TextBlock Text="Ejemplo: Repuestos, Máquinas, Accesorios" FontSize="10" Foreground="#605E5C" FontStyle="Italic" Margin="0,5,0,0"/>
                    <TextBlock x:Name="ProductosError" Style="{StaticResource ErrorLabelStyle}"/>
                </StackPanel>

                <!-- Observaciones -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Observaciones" FontSize="12" FontWeight="SemiBold" Foreground="#323130"/>
                    <TextBox x:Name="ObservacionesTextBox" Style="{StaticResource FluentTextAreaStyle}" Height="80" Margin="0,5,0,0"/>
                    <TextBlock x:Name="ObservacionesError" Style="{StaticResource ErrorLabelStyle}"/>
                </StackPanel>

                <!-- Error General -->
                <TextBlock x:Name="GeneralError" Style="{StaticResource ErrorLabelStyle}" TextWrapping="Wrap" Margin="0,10,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Botones de acción -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E1E1E1" BorderThickness="0,1" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="StatusTextBlock" Text="" FontSize="11" Foreground="#605E5C" VerticalAlignment="Center"/>

                <Button Grid.Column="1" x:Name="GuardarButton" Content="💾 Guardar" Style="{StaticResource FluentButtonStyle}"
                       Click="GuardarButton_Click" Margin="0,0,10,0"/>
                <Button Grid.Column="2" Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}"
                       Click="CancelarButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
