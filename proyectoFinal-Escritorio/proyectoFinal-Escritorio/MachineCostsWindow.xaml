<Window x:Class="proyectoFinal_Escritorio.MachineCostsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestión de Costos - Sistema de Gestión" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal">

    <Window.Resources>
        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F9FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}">
            <Setter Property="Background" Value="#D13438"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#A4262C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FluentComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="28"/>
        </Style>

        <Style x:Key="FluentTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="IsReadOnly" Value="False"/>
            <Setter Property="IsEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                        Focusable="False"
                                        HorizontalScrollBarVisibility="Hidden"
                                        VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#0078D4"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="Padding" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="4" BlurRadius="8" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Height="80">
            <Border.Effect>
                <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
            </Border.Effect>
            <Grid Margin="30,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="MachineHeaderText" Text="Gestión de Costos" FontSize="24" FontWeight="SemiBold" Foreground="#323130"/>
                    <TextBlock Text="Seguimiento y control de gastos de reparación y mantenimiento" FontSize="14" Foreground="#605E5C"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="CloseButton" Content="❌ Cerrar" Style="{StaticResource SecondaryButtonStyle}" Margin="5,0" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Estadísticas -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="30,20,30,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Total Reparaciones" FontSize="12" Foreground="#605E5C" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TotalRepairCostsText" Text="$0.00" FontSize="18" Foreground="#D13438" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Total Mantenimiento" FontSize="12" Foreground="#605E5C" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TotalMaintenanceCostsText" Text="$0.00" FontSize="18" Foreground="#FF8C00" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Costo Total" FontSize="12" Foreground="#605E5C" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TotalCostsText" Text="$0.00" FontSize="18" Foreground="#107C10" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="Cantidad de Registros" FontSize="12" Foreground="#605E5C" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TotalCountText" Text="0" FontSize="18" Foreground="#0078D4" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid de gastos -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="30,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Historial de Costos" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="#323130"/>

                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="TipoCostoFilterComboBox" Grid.Column="0" Style="{StaticResource FluentComboBoxStyle}" Margin="0,0,10,0" SelectionChanged="FilterChanged"/>
                    <Button x:Name="ClearFiltersButton" Grid.Column="2" Content="🗑️ Limpiar" Style="{StaticResource SecondaryButtonStyle}" Click="ClearFiltersButton_Click"/>
                </Grid>

                <DataGrid Grid.Row="2" x:Name="CostsDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" CanUserReorderColumns="True" CanUserResizeColumns="True" GridLinesVisibility="Horizontal" Background="White" AlternatingRowBackground="#F8F9FA" RowHeight="40" FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tipo de Costo" Binding="{Binding TipoCostoCapitalizado}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Monto" Binding="{Binding MontoFormateado}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Fecha" Binding="{Binding FechaFormateada}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="200" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Proveedor" Binding="{Binding Proveedor}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Factura" Binding="{Binding NumeroFactura}" Width="100" IsReadOnly="True"/>

                        <DataGridTemplateColumn Header="Acciones" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="👁️" Style="{StaticResource SecondaryButtonStyle}" Width="30" Height="26" Margin="2" Padding="0" FontSize="10" ToolTip="Ver detalles" Click="ViewCostButton_Click" Tag="{Binding}"/>
                                        <Button Content="🗑️" Style="{StaticResource DangerButtonStyle}" Width="30" Height="26" Margin="2" Padding="0" FontSize="10" ToolTip="Eliminar" Click="DeleteCostButton_Click" Tag="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="White" Height="30" BorderBrush="#E1E1E1" BorderThickness="0,1,0,0">
            <Grid Margin="30,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="StatusText" Text="Listo" VerticalAlignment="Center" FontSize="11" Foreground="#605E5C"/>
                <TextBlock Grid.Column="1" x:Name="LastUpdateText" Text="" VerticalAlignment="Center" FontSize="11" Foreground="#605E5C"/>
            </Grid>
        </Border>
    </Grid>
</Window>
