<Window x:Class="proyectoFinal_Escritorio.MachineStateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Actualizar Estado de Máquina" Height="550" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Reutilizar estilos -->
        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F9FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FluentTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>

        <Style x:Key="FluentComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="32"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="Padding" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="4" BlurRadius="8" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Height="60">
            <Border.Effect>
                <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
            </Border.Effect>
            <Grid Margin="30,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Actualizar Estado de Máquina" 
                             FontSize="18" 
                             FontWeight="SemiBold" 
                             FontFamily="Segoe UI" 
                             Foreground="#323130"/>
                    <TextBlock x:Name="MachineInfoText"
                             Text="Cambiar el estado operativo del equipo" 
                             FontSize="11" 
                             FontFamily="Segoe UI" 
                             Foreground="#605E5C"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Form Content -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="20">
            <StackPanel>
                <!-- Información actual -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Información Actual" 
                             FontSize="14" FontWeight="SemiBold" 
                             Margin="0,0,0,10" Foreground="#323130"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Número de Serie:" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="NumeroSerieText" 
                                 Text="" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Tipo/Modelo:" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TipoModeloText" 
                                 Text="" VerticalAlignment="Center" Margin="10,0,0,0"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Estado Actual:" Style="{StaticResource LabelStyle}"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                            <Ellipse x:Name="EstadoActualEllipse" Width="12" Height="12" Margin="0,0,8,0"/>
                            <TextBlock x:Name="EstadoActualText" Text="" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Separador -->
                <Border Height="1" Background="#E1E1E1" Margin="0,10,0,20"/>

                <!-- Nuevo estado -->
                <StackPanel>
                    <TextBlock Text="Actualizar Estado" 
                             FontSize="14" FontWeight="SemiBold" 
                             Margin="0,0,0,15" Foreground="#323130"/>
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Nuevo Estado -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                            <Label Content="* Nuevo Estado:" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="NuevoEstadoComboBox" 
                                    Style="{StaticResource FluentComboBoxStyle}"
                                    SelectionChanged="NuevoEstadoComboBox_SelectionChanged"/>
                        </StackPanel>

                        <!-- Motivo del cambio -->
                        <StackPanel Grid.Row="1" Margin="0,0,0,15">
                            <Label Content="* Motivo del cambio:" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="MotivoTextBox" 
                                   Style="{StaticResource FluentTextBoxStyle}"
                                   Height="60"
                                   TextWrapping="Wrap"
                                   AcceptsReturn="True"
                                   VerticalContentAlignment="Top"/>
                        </StackPanel>

                        <!-- Registrar horas de uso adicionales -->
                        <StackPanel Grid.Row="2" x:Name="HorasUsoPanel" Visibility="Collapsed">
                            <Label Content="Horas de uso adicionales:" Style="{StaticResource LabelStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="HorasUsoTextBox" 
                                       Grid.Column="0"
                                       Style="{StaticResource FluentTextBoxStyle}"
                                       Text="0"
                                       Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="horas" VerticalAlignment="Center" Foreground="#605E5C"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Información adicional -->
                <Border Background="#F8F9FA" 
                      CornerRadius="4" 
                      Padding="15" 
                      Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock Text="💡 Información" 
                                 FontWeight="SemiBold" 
                                 Margin="0,0,0,5" 
                                 Foreground="#323130"/>
                        <TextBlock x:Name="InfoText"
                                 Text="Selecciona el nuevo estado y proporciona un motivo para el cambio. Esta acción quedará registrada en el historial de la máquina." 
                                 TextWrapping="Wrap"
                                 FontSize="11" 
                                 Foreground="#605E5C"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Action Buttons -->
        <Border Grid.Row="2" Background="White" Height="60" BorderBrush="#E1E1E1" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="30,0">
                <Button x:Name="CancelButton" 
                      Content="Cancelar" 
                      Style="{StaticResource SecondaryButtonStyle}" 
                      Width="100" 
                      Margin="0,0,10,0"
                      Click="CancelButton_Click"/>
                <Button x:Name="UpdateButton" 
                      Content="Actualizar Estado" 
                      Style="{StaticResource FluentButtonStyle}" 
                      Width="140"
                      Click="UpdateButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>