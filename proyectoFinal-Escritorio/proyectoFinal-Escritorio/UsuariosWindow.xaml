<Window x:Class="proyectoFinal_Escritorio.UsuariosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestión de Usuarios - Sistema de Gestión" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Reutilizar estilos del MainWindow -->
        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F3F3F3"/>
                                <Setter Property="Foreground" Value="#A6A6A6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F9FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#DEECF9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}">
            <Setter Property="Background" Value="#D13438"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#A4262C"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#8B1538"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FluentTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="28"/>
        </Style>

        <Style x:Key="FluentComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="28"/>
        </Style>

        <Style x:Key="FluentDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="28"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="30,20" Margin="0,0,0,1">
            <Border.Effect>
                <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Gestión de Usuarios" FontSize="24" FontWeight="SemiBold" Foreground="#323130" Margin="0,0,0,5"/>
                    <TextBlock Text="Administrar usuarios del sistema - Crear, editar, eliminar y filtrar usuarios" FontSize="14" Foreground="#605E5C"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="RefreshButton" Content="🔄 Actualizar" Style="{StaticResource SecondaryButtonStyle}" Click="RefreshButton_Click" Margin="5,0"/>
                    <Button x:Name="AddUserButton" Content="➕ Nuevo Usuario" Style="{StaticResource FluentButtonStyle}" Click="AddUserButton_Click" Margin="5,0"/>
                    <Button x:Name="BackButton" Content="← Volver" Style="{StaticResource SecondaryButtonStyle}" Click="BackButton_Click" Margin="5,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filters Section -->
        <Border Grid.Row="1" Background="White" Padding="30,15" Margin="0,0,0,1">
            <Border.Effect>
                <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="1" BlurRadius="3" Opacity="0.2"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Filtros:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                
                <ComboBox x:Name="RolFilterComboBox" Grid.Column="1" Style="{StaticResource FluentComboBoxStyle}" 
                         SelectionChanged="FilterChanged" SelectedIndex="0">
                    <ComboBoxItem Content="Todos los roles"/>
                    <ComboBoxItem Content="Administrador"/>
                    <ComboBoxItem Content="Empleado"/>
                    <ComboBoxItem Content="Cliente"/>
                </ComboBox>

                <TextBlock Grid.Column="2" Text="Edad:" VerticalAlignment="Center" Margin="15,0,8,0"/>
                <ComboBox x:Name="EdadFilterComboBox" Grid.Column="3" Style="{StaticResource FluentComboBoxStyle}" 
                         SelectionChanged="FilterChanged" SelectedIndex="0">
                    <ComboBoxItem Content="Todas las edades"/>
                    <ComboBoxItem Content="Mayor de edad (≥18)"/>
                    <ComboBoxItem Content="Menor de edad (&lt;18)"/>
                </ComboBox>

                <TextBlock Grid.Column="4" Text="Ciudad:" VerticalAlignment="Center" Margin="15,0,8,0"/>
                <ComboBox x:Name="CiudadFilterComboBox" Grid.Column="5" Style="{StaticResource FluentComboBoxStyle}" 
                         SelectionChanged="FilterChanged" SelectedIndex="0">
                    <ComboBoxItem Content="Todas las ciudades"/>
                </ComboBox>

                <TextBlock Grid.Column="6" Text="Reputación:" VerticalAlignment="Center" Margin="15,0,8,0"/>
                <ComboBox x:Name="ReputacionFilterComboBox" Grid.Column="7" Style="{StaticResource FluentComboBoxStyle}" 
                         SelectionChanged="FilterChanged" SelectedIndex="0">
                    <ComboBoxItem Content="Todas"/>
                    <ComboBoxItem Content="≥ 80 (Excelente)"/>
                    <ComboBoxItem Content="60-79 (Buena)"/>
                    <ComboBoxItem Content="40-59 (Regular)"/>
                    <ComboBoxItem Content="&lt; 40 (Mala)"/>
                </ComboBox>

                <Button Grid.Column="9" Content="🔍 Buscar" Style="{StaticResource FluentButtonStyle}" Click="ApplyFilters_Click"/>
            </Grid>
        </Border>

        <!-- Users DataGrid -->
        <Border Grid.Row="2" Background="White" Margin="30,15,30,30" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="4" BlurRadius="8" Opacity="0.4"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Status Bar -->
                <Border Grid.Row="0" Background="#F8F9FA" Padding="20,10" CornerRadius="8,8,0,0">
                    <Grid>
                        <TextBlock x:Name="StatusTextBlock" Text="Cargando usuarios..." FontSize="12" Foreground="#605E5C" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock x:Name="TotalUsersText" Text="Total: 0 usuarios" FontSize="12" Foreground="#323130" VerticalAlignment="Center" Margin="0,0,15,0"/>
                            <ProgressBar x:Name="LoadingProgressBar" Width="100" Height="4" IsIndeterminate="True" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- DataGrid -->
                <DataGrid x:Name="UsersDataGrid" Grid.Row="1" 
                         AutoGenerateColumns="False" 
                         IsReadOnly="True"
                         SelectionMode="Single"
                         GridLinesVisibility="Horizontal"
                         HeadersVisibility="Column"
                         CanUserResizeColumns="True"
                         CanUserSortColumns="True"
                         Background="White"
                         BorderThickness="0"
                         FontSize="12"
                         FontFamily="Segoe UI"
                         RowHeight="35"
                         SelectionChanged="UsersDataGrid_SelectionChanged">
                    
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="DNI" Binding="{Binding Dni}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding NombreCompleto}" Width="180" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Rol" Binding="{Binding RolCapitalizado}" Width="80" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Edad" Binding="{Binding Edad}" Width="50" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Ciudad" Binding="{Binding Ciudad}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Membresía" Binding="{Binding TipoMembresia}" Width="80" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Tiempo Restante" Binding="{Binding TiempoRestanteMembresia}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Descuento Actual %" Binding="{Binding DescuentoActual}" Width="100" IsReadOnly="True"/>
                    </DataGrid.Columns>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F3F9FD"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DEECF9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>

                <!-- Action Buttons -->
                <Border Grid.Row="2" Background="#F8F9FA" Padding="20,15" CornerRadius="0,0,8,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="SelectedUserInfo" Text="Selecciona un usuario para ver las acciones disponibles" 
                                 FontSize="12" Foreground="#605E5C" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button x:Name="ViewUserButton" Content="👁️ Ver" Style="{StaticResource SecondaryButtonStyle}" 
                               Click="ViewUserButton_Click" IsEnabled="False" Margin="5,0"/>
                        <Button x:Name="EditUserButton" Content="✏️ Editar" Style="{StaticResource FluentButtonStyle}" 
                               Click="EditUserButton_Click" IsEnabled="False" Margin="5,0"/>
                        <Button x:Name="DeleteUserButton" Content="🗑️ Eliminar" Style="{StaticResource DangerButtonStyle}" 
                               Click="DeleteUserButton_Click" IsEnabled="False" Margin="5,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>