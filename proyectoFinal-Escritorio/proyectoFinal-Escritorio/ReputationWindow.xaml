<Window x:Class="proyectoFinal_Escritorio.ReputationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema de Reputación - Sanciones y Recompensas" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Convertidores -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Estilos Fluent Design -->
        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F3F3F3"/>
                                <Setter Property="Foreground" Value="#A6A6A6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F9FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#DEECF9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}">
            <Setter Property="Background" Value="#107C10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0E6B0E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}">
            <Setter Property="Background" Value="#D13438"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#A4262C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RewardButtonStyle" TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}">
            <Setter Property="Background" Value="#FF8C00"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E67E00"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FluentTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="4" BlurRadius="8" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Template para reputación -->
        <DataTemplate x:Key="ReputacionDataTemplate">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="{Binding Reputacion}" 
                         FontWeight="Bold" 
                         FontSize="14"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0">
                    <!--estos estilos se encargan de cambiar el color del numero de reputacion dependiendo de que tan alta o baja sea-->
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EsReputacionAlta}" Value="True">
                                    <Setter Property="Foreground" Value="#107C10"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding EsReputacionBaja}" Value="True">
                                    <Setter Property="Foreground" Value="#D13438"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding EsReputacionMedia}" Value="True">
                                    <Setter Property="Foreground" Value="#FF8C00"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                
                <Border Background="#FF8C00" 
                      CornerRadius="10" 
                      Width="20" Height="20"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Visibility="{Binding PuedeRecibirPremio, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="🏆" 
                             Foreground="White" 
                             FontSize="10" 
                             FontWeight="Bold"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <!--color del fondo de la ventana-->
    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Height="80">
            <Border.Effect>
                <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
            </Border.Effect>
            <Grid Margin="30,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Sistema de Reputación" 
                             FontSize="24" 
                             FontWeight="SemiBold" 
                             FontFamily="Segoe UI" 
                             Foreground="#323130"/>
                    <TextBlock Text="Gestión de sanciones y recompensas para clientes" 
                             FontSize="14" 
                             FontFamily="Segoe UI" 
                             Foreground="#605E5C"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BackButton" 
                          Content="⬅️ Volver" 
                          Style="{StaticResource SecondaryButtonStyle}" 
                          Margin="5,0"
                          Click="BackButton_Click"/>
                    <Button x:Name="RefreshButton" 
                          Content="🔄 Actualizar" 
                          Style="{StaticResource SecondaryButtonStyle}" 
                          Margin="5,0"
                          Click="RefreshButton_Click"/>
                    <Button x:Name="HistoryButton" 
                          Content="📊 Historial General" 
                          Style="{StaticResource SecondaryButtonStyle}" 
                          Margin="5,0"
                          Click="HistoryButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filtros y estadísticas -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="30,20,30,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="Estadísticas"
                         FontSize="16" FontWeight="SemiBold"
                         Margin="0,0,0,15" Foreground="#323130"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Estadísticas -->
                    <Border Grid.Column="0" Background="#E8F5E8" CornerRadius="6" Padding="10" Margin="5,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="HighReputationText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#107C10" HorizontalAlignment="Center"/>
                            <TextBlock Text="Reputación Alta" FontSize="10" Foreground="#605E5C" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#FFF3E0" CornerRadius="6" Padding="10" Margin="5,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="MediumReputationText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#FF8C00" HorizontalAlignment="Center"/>
                            <TextBlock Text="Reputación Media" FontSize="10" Foreground="#605E5C" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#FFEBEE" CornerRadius="6" Padding="10" Margin="5,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="LowReputationText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#D13438" HorizontalAlignment="Center"/>
                            <TextBlock Text="Reputación Baja" FontSize="10" Foreground="#605E5C" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Background="#E3F2FD" CornerRadius="6" Padding="10" Margin="5,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="EligibleForRewardText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#0078D4" HorizontalAlignment="Center"/>
                            <TextBlock Text="Elegibles Premio" FontSize="10" Foreground="#605E5C" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Lista de clientes -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="30,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock x:Name="ClientCountText"
                             Text="Clientes registrados" 
                             FontSize="16" FontWeight="SemiBold" 
                             Foreground="#323130"/>
                </Grid>
                
                <DataGrid Grid.Row="1" 
                        x:Name="ClientsDataGrid"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        CanUserReorderColumns="True"
                        CanUserResizeColumns="True"
                        CanUserResizeRows="False"
                        CanUserSortColumns="True"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        HorizontalGridLinesBrush="#F0F0F0"
                        Background="White"
                        AlternatingRowBackground="#F8F9FA"
                        RowHeight="50"
                        FontSize="12"
                        FontFamily="Segoe UI"
                        SelectionMode="Single"
                        SelectionChanged="ClientsDataGrid_SelectionChanged">
                    
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="DNI" 
                                          Binding="{Binding Dni}" 
                                          Width="100"
                                          IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTextColumn Header="Nombre Completo" 
                                          Binding="{Binding NombreCompleto}" 
                                          Width="200"
                                          IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTextColumn Header="Email" 
                                          Binding="{Binding Email}" 
                                          Width="200"
                                          IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTemplateColumn Header="Reputación" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentPresenter Content="{Binding}" 
                                                    ContentTemplate="{StaticResource ReputacionDataTemplate}" 
                                                    VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTextColumn Header="Membresía" 
                                          Binding="{Binding TipoMembresia}" 
                                          Width="100"
                                          IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTextColumn Header="Registro" 
                                          Binding="{Binding FechaRegistroFormateada}" 
                                          Width="100"
                                          IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="11"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTemplateColumn Header="Acciones" Width="280">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <!-- Sanción -->
                                        <Button Content="➖ Sanción" 
                                              Style="{StaticResource DangerButtonStyle}"
                                              Width="80" Height="26"
                                              Margin="2" Padding="0"
                                              FontSize="10"
                                              ToolTip="Aplicar sanción (-5 puntos)"
                                              Click="SancionButton_Click"
                                              Tag="{Binding}"/>
                                        
                                        <!-- Recompensa -->
                                        <Button Content="➕ Recompensa" 
                                              Style="{StaticResource SuccessButtonStyle}"
                                              Width="80" Height="26"
                                              Margin="2" Padding="0"
                                              FontSize="10"
                                              ToolTip="Aplicar recompensa (+5 puntos)"
                                              Click="RecompensaButton_Click"
                                              Tag="{Binding}"/>
                                        
                                        <!-- Premio especial -->
                                        <Button Content="🏆 Premio" 
                                              Style="{StaticResource RewardButtonStyle}"
                                              Width="70" Height="26"
                                              Margin="2" Padding="0"
                                              FontSize="10"
                                              ToolTip="Otorgar premio especial"
                                              Click="PremioButton_Click"
                                              Tag="{Binding}"
                                              Visibility="{Binding PuedeRecibirPremio, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        
                                        <!-- Historial -->
                                        <Button Content="📋 Historial" 
                                              Style="{StaticResource SecondaryButtonStyle}"
                                              Width="70" Height="26"
                                              Margin="2" Padding="0"
                                              FontSize="10"
                                              ToolTip="Ver historial de reputación"
                                              Click="HistorialButton_Click"
                                              Tag="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="White" Height="30" BorderBrush="#E1E1E1" BorderThickness="0,1,0,0">
            <Grid Margin="30,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                         x:Name="StatusText"
                         Text="Listo" 
                         VerticalAlignment="Center"
                         FontSize="11" 
                         Foreground="#605E5C"/>
                
                <TextBlock Grid.Column="1" 
                         x:Name="LastUpdateText"
                         Text="" 
                         VerticalAlignment="Center"
                         FontSize="11" 
                         Foreground="#605E5C"/>
            </Grid>
        </Border>
    </Grid>
</Window>